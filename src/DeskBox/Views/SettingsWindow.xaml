                                <FontIcon Glyph="&#xE81E;" />
                            </toolkit:SettingsCard.HeaderIcon>
                            <ToggleSwitch
                                MinWidth="0"
                                OffContent=""
                                OnContent=""
                                IsOn="{Binding FileStacksEnabled, Mode=TwoWay}" />
                        </toolkit:SettingsCard>

                        <toolkit:SettingsCard
                            HorizontalContentAlignment="Right"
                            IsEnabled="{Binding FileStacksEnabled}"
