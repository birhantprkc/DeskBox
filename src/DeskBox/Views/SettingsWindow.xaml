                            </Button>
                        </toolkit:SettingsCard>
                        <toolkit:SettingsCard Description="{Binding CapsuleGeometryOverrideSummaryText}" HorizontalContentAlignment="Right" svc:Localized.HeaderKey="Settings.Capsule.Overrides.Geometry.Title">
                            <Button Command="{Binding ResetCapsuleGeometryOverridesCommand}" IsEnabled="{Binding HasCapsuleGeometryOverrides}">
                                <StackPanel Orientation="Horizontal" Spacing="6"><FontIcon FontSize="13" Glyph="&#xE72C;" /><TextBlock svc:Localized.Key="Settings.Capsule.Overrides.ResetGeometry" /></StackPanel>
                            </Button>
                        </toolkit:SettingsCard>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="AppearanceDetailSection"
                    Visibility="Collapsed"
                    Style="{StaticResource SectionPanelStyle}">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" svc:Localized.Key="Settings.Appearance.DetailTitle" />
                    <StackPanel Margin="0,8,0,0" Spacing="4">
                        <Border Style="{StaticResource SettingsGroupStyle}">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="4">
                                <Button Grid.Column="0" Click="NestedSettingsButton_Click" Style="{StaticResource DrillDownRowStyle}" Tag="FileDisplaySettings">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <FontIcon Grid.Column="0" FontSize="18" Glyph="&#xE8A5;" IsHitTestVisible="False" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" IsHitTestVisible="False" Spacing="3" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.Group.FileLayout.Title" />
                                            <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.Group.FileLayout.Description" />
                                        </StackPanel>
                                        <FontIcon Grid.Column="2" FontSize="12" Glyph="&#xE76C;" IsHitTestVisible="False" VerticalAlignment="Center" />
                                    </Grid>
                                </Button>
                                <ToggleSwitch
                                    Grid.Column="1"
                                    MinWidth="0"
                                    OffContent=""
                                    OnContent=""
                                    VerticalAlignment="Center"
                                    IsOn="{Binding ShowFileExtensions, Mode=TwoWay}" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SettingsGroupStyle}">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="4">
                                <Button Grid.Column="0" Click="NestedSettingsButton_Click" Style="{StaticResource DrillDownRowStyle}" Tag="FileStackSettings">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <FontIcon Grid.Column="0" FontSize="18" Glyph="&#xE81E;" IsHitTestVisible="False" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" IsHitTestVisible="False" Spacing="3" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.FileStacks.Title" />
                                            <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding FileStackSettingsSummaryText}" />
