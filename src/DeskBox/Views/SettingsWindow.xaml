                            <ToggleSwitch OnContent="" OffContent="" MinWidth="0" IsOn="{Binding ShowFileItemPathTooltips, Mode=TwoWay}" />
                        </toolkit:SettingsCard>
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="FileStorageSettingsSection" Visibility="Collapsed" Style="{StaticResource SectionPanelStyle}">
                    <StackPanel Margin="0,8,0,0" Spacing="4">
                        <toolkit:SettingsCard ContentAlignment="Vertical" HorizontalContentAlignment="Stretch" Padding="20,16" svc:Localized.HeaderKey="Settings.Group.FileStorage.Title">
                            <toolkit:SettingsCard.HeaderIcon><FontIcon Glyph="&#xE8B7;" /></toolkit:SettingsCard.HeaderIcon>
                            <StackPanel Spacing="12">
                                <TextBox IsReadOnly="True" Text="{Binding ManagedStorageRootPath, Mode=OneWay}" TextWrapping="NoWrap" />
                                <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding QuickAccessStatusText}" />
                                <StackPanel x:Name="PathActionsPanel" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="OpenPathButton" Click="OpenManagedStoragePathButton_Click" Style="{StaticResource ActionButtonStyle}" svc:Localized.ToolTipKey="Settings.ManagedPath.OpenTooltip">
                                        <StackPanel Orientation="Horizontal" Spacing="8"><SymbolIcon Symbol="OpenFile" /><TextBlock svc:Localized.Key="Common.Open" /></StackPanel>
                                    </Button>
                                    <Button x:Name="PinQuickAccessButton" Click="PinManagedStorageToQuickAccessButton_Click" IsEnabled="{Binding CanInvokeQuickAccessAction}" Style="{StaticResource ActionButtonStyle}" ToolTipService.ToolTip="{Binding PinQuickAccessToolTipText}">
