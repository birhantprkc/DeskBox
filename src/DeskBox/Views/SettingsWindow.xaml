                                </toolkit:SettingsCard>

                                <toolkit:SettingsCard
                                    HorizontalContentAlignment="Right"
                                    svc:Localized.DescriptionKey="Settings.Todo.ConfirmBeforeDelete.Description"
                                    svc:Localized.HeaderKey="Settings.Todo.ConfirmBeforeDelete.Title">
                                    <ToggleSwitch
                                        MinWidth="0"
                                        IsOn="{Binding TodoConfirmBeforeDelete, Mode=TwoWay}" />
                                </toolkit:SettingsCard>
                            </toolkit:SettingsExpander.Items>
                        </toolkit:SettingsExpander>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="MusicSettingsSection"
                    Visibility="Collapsed"
                    Style="{StaticResource SectionPanelStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.Music.PageDescription" />
                    </StackPanel>
                    <StackPanel Margin="0,8,0,0" Spacing="4">
                        <toolkit:SettingsCard
                            HorizontalContentAlignment="Right"
                            svc:Localized.DescriptionKey="Settings.Music.ArtworkBackdrop.Description"
                            svc:Localized.HeaderKey="Settings.Music.ArtworkBackdrop.Title">
                            <toolkit:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xEB9F;" />
                            </toolkit:SettingsCard.HeaderIcon>
                            <ToggleSwitch
                                MinWidth="0"
                                IsOn="{Binding MusicUseArtworkBackdrop, Mode=TwoWay}" />
                        </toolkit:SettingsCard>

                        <toolkit:SettingsCard
                            HorizontalContentAlignment="Right"
                            svc:Localized.DescriptionKey="Settings.Music.RhythmBars.Description"
                            svc:Localized.HeaderKey="Settings.Music.RhythmBars.Title">
                            <toolkit:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE9D2;" />
                            </toolkit:SettingsCard.HeaderIcon>
                            <ToggleSwitch
                                MinWidth="0"
                                IsOn="{Binding MusicShowRhythmBars, Mode=TwoWay}" />
                        </toolkit:SettingsCard>

                        <toolkit:SettingsCard
                            HorizontalContentAlignment="Right"
                            svc:Localized.DescriptionKey="Settings.Music.RhythmStyle.Description"
                            svc:Localized.HeaderKey="Settings.Music.RhythmStyle.Title">
                            <toolkit:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE7F8;" />
                            </toolkit:SettingsCard.HeaderIcon>
                            <ComboBox
                                MinWidth="176"
                                ItemsSource="{Binding AvailableMusicRhythmStyleDisplayNames}"
                                SelectedIndex="{Binding SelectedMusicRhythmStyleIndex, Mode=OneWay}"
                                SelectionChanged="SettingsComboBox_SelectionChanged"
                                Tag="MusicRhythmStyle" />
                        </toolkit:SettingsCard>

                        <toolkit:SettingsExpander
                            IsExpanded="False"
                            svc:Localized.DescriptionKey="Settings.Music.Group.Motion.Description"
                            svc:Localized.HeaderKey="Settings.Music.Group.Motion.Title">
                            <toolkit:SettingsExpander.HeaderIcon>
                                <FontIcon Glyph="&#xE7F8;" />
                            </toolkit:SettingsExpander.HeaderIcon>
                            <toolkit:SettingsExpander.Items>
                                <toolkit:SettingsCard
                                    HorizontalContentAlignment="Right"
                                    svc:Localized.DescriptionKey="Settings.Music.CoverHoverMotion.Description"
                                    svc:Localized.HeaderKey="Settings.Music.CoverHoverMotion.Title">
                                    <ToggleSwitch
                                        MinWidth="0"
                                        IsOn="{Binding MusicEnableCoverHoverMotion, Mode=TwoWay}" />
                                </toolkit:SettingsCard>
                            </toolkit:SettingsExpander.Items>
                        </toolkit:SettingsExpander>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="GeneralSection"
                    Style="{StaticResource SectionPanelStyle}">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" svc:Localized.Key="Settings.Section.General" />
                    <StackPanel Margin="0,8,0,0" Spacing="4">
                        <toolkit:SettingsCard
                            HorizontalContentAlignment="Right"
                            svc:Localized.DescriptionKey="Settings.Language.Description"
                            svc:Localized.HeaderKey="Settings.Language.Title">
                            <toolkit:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE774;" />
                            </toolkit:SettingsCard.HeaderIcon>
                            <ComboBox
                                MinWidth="176"
                                ItemsSource="{Binding AvailableLanguageDisplayNames}"
                                SelectedIndex="{Binding SelectedLanguageIndex, Mode=OneWay}"
                                SelectionChanged="SettingsComboBox_SelectionChanged"
                                Tag="Language" />
                        </toolkit:SettingsCard>

                        <toolkit:SettingsCard
                            HorizontalContentAlignment="Right"
                            svc:Localized.DescriptionKey="Settings.AutoStart.Description"
                            svc:Localized.HeaderKey="Settings.AutoStart.Title">
                            <toolkit:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE7C1;" />
                            </toolkit:SettingsCard.HeaderIcon>
                            <ToggleSwitch
                                MinWidth="0"
                                IsOn="{Binding AutoStart, Mode=TwoWay}" />
                        </toolkit:SettingsCard>

                        <toolkit:SettingsCard
                            HorizontalContentAlignment="Right"
                            svc:Localized.DescriptionKey="Settings.DoubleClick.Description"
                            svc:Localized.HeaderKey="Settings.DoubleClick.Title">
                            <toolkit:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE7C9;" />
                            </toolkit:SettingsCard.HeaderIcon>
                            <ToggleSwitch
                                MinWidth="0"
                                IsOn="{Binding DoubleClickToOpen, Mode=TwoWay}" />
                        </toolkit:SettingsCard>

                        <toolkit:SettingsCard
                            HorizontalContentAlignment="Right"
                            svc:Localized.DescriptionKey="Settings.Onboarding.Description"
                            svc:Localized.HeaderKey="Settings.Onboarding.Title">
                            <toolkit:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE82D;" />
                            </toolkit:SettingsCard.HeaderIcon>
                            <Button
                                Click="ShowOnboardingButton_Click"
                                Style="{StaticResource ActionButtonStyle}"
                                svc:Localized.ToolTipKey="Settings.Onboarding.Tooltip">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="14" Glyph="&#xE82D;" />
                                    <TextBlock svc:Localized.Key="Common.View" />
                                </StackPanel>
                            </Button>
                        </toolkit:SettingsCard>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="MaintenanceSection"
                    Visibility="Collapsed"
                    Style="{StaticResource SectionPanelStyle}">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" svc:Localized.Key="Settings.Section.Maintenance" />
                    <StackPanel Margin="0,8,0,0" Spacing="4">
                        <toolkit:SettingsCard
                            HorizontalContentAlignment="Right"
                            svc:Localized.DescriptionKey="Settings.Restore.Description"
                            svc:Localized.HeaderKey="Settings.Restore.Title">
                            <toolkit:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE72C;" />
                            </toolkit:SettingsCard.HeaderIcon>
                            <Button
                                Click="RestoreDefaultSettingsButton_Click"
                                Style="{StaticResource ActionButtonStyle}"
                                svc:Localized.ToolTipKey="Settings.Restore.Tooltip">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Refresh" />
                                    <TextBlock svc:Localized.Key="Common.Restore" />
                                </StackPanel>
                            </Button>
                        </toolkit:SettingsCard>

                        <toolkit:SettingsCard
                            ContentAlignment="Vertical"
                            HorizontalContentAlignment="Stretch"
                            svc:Localized.DescriptionKey="Settings.DragDropPermission.Description"
                            svc:Localized.HeaderKey="Settings.DragDropPermission.Title">
                            <toolkit:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8A7;" />
                            </toolkit:SettingsCard.HeaderIcon>
                            <StackPanel Spacing="12">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Style="{StaticResource SettingDescriptionTextStyle}"
                                    Text="{Binding DragDropPermissionSummaryText}" />
                                <TextBlock
                                    Style="{StaticResource SettingDescriptionTextStyle}"
                                    Text="{Binding DragDropPermissionDetailText}" />

                                <Grid ColumnSpacing="16" RowSpacing="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="112" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingValueTextStyle}" svc:Localized.Key="Settings.DragDropPermission.ProcessLabel" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding DragDropPermissionProcessText}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource SettingValueTextStyle}" svc:Localized.Key="Settings.DragDropPermission.ExplorerLabel" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding DragDropPermissionExplorerText}" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource SettingValueTextStyle}" svc:Localized.Key="Settings.DragDropPermission.UacLabel" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding DragDropPermissionUacText}" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource SettingValueTextStyle}" svc:Localized.Key="Settings.DragDropPermission.AppCompatLabel" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding DragDropPermissionAppCompatText}" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource SettingValueTextStyle}" svc:Localized.Key="Settings.DragDropPermission.StartupLabel" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding DragDropPermissionStartupText}" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource SettingValueTextStyle}" svc:Localized.Key="Settings.DragDropPermission.ShortcutLabel" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding DragDropPermissionShortcutText}" />
                                </Grid>

                                <TextBlock
                                    Style="{StaticResource SettingDescriptionTextStyle}"
                                    Text="{Binding DragDropPermissionRepairStatusText}" />

                                <StackPanel
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Button
                                        Click="RefreshDragDropPermissionButton_Click"
                                        Style="{StaticResource ActionButtonStyle}"
                                        svc:Localized.ToolTipKey="Settings.DragDropPermission.RefreshTooltip">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Refresh" />
                                            <TextBlock svc:Localized.Key="Common.Refresh" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        Click="RepairDragDropPermissionButton_Click"
                                        IsEnabled="{Binding CanRepairDragDropPermission}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        svc:Localized.ToolTipKey="Settings.DragDropPermission.RepairTooltip">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Setting" />
                                            <TextBlock svc:Localized.Key="Settings.DragDropPermission.RepairButton" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        Click="OpenUacSettingsButton_Click"
                                        Style="{StaticResource ActionButtonStyle}"
                                        svc:Localized.ToolTipKey="Settings.DragDropPermission.OpenUacTooltip">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="OpenFile" />
                                            <TextBlock svc:Localized.Key="Settings.DragDropPermission.OpenUacButton" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </toolkit:SettingsCard>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="AboutSection"
                    Visibility="Collapsed"
                    Style="{StaticResource SectionPanelStyle}">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" svc:Localized.Key="Settings.Section.About" />
                    <StackPanel Margin="0,8,0,0" Spacing="4">
                        <toolkit:SettingsCard
                            Header="DeskBox"
                            Description="{Binding AboutVersionText}"
                            HorizontalContentAlignment="Right"
                            svc:Localized.DescriptionKey="Settings.About.Description">
                            <toolkit:SettingsCard.HeaderIcon>
                                <BitmapIcon UriSource="ms-appx:///Assets/deskbox.svg" />
                            </toolkit:SettingsCard.HeaderIcon>
                            <TextBlock
                                VerticalAlignment="Center"
                                Style="{StaticResource SettingValueTextStyle}"
                                Text="{Binding AboutVersionText}" />
                        </toolkit:SettingsCard>

                        <toolkit:SettingsCard
                            ContentAlignment="Vertical"
                            HorizontalContentAlignment="Stretch"
                            svc:Localized.DescriptionKey="Settings.Download.Description"
                            svc:Localized.HeaderKey="Settings.Download.Title">
                            <toolkit:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE896;" />
                            </toolkit:SettingsCard.HeaderIcon>
                            <StackPanel Spacing="12">
                                <TextBox
                                    IsReadOnly="True"
                                    Text="https://pan.quark.cn/s/f7a6769cdaf3"
                                    TextWrapping="NoWrap" />
                                <StackPanel
                                    x:Name="DownloadLinkActionsPanel"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Button
                                        x:Name="CopyDownloadLinkButton"
                                        Click="CopyDownloadLinkButton_Click"
                                        Style="{StaticResource ActionButtonStyle}"
                                        svc:Localized.ToolTipKey="Settings.Download.CopyTooltip">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Copy" />
                                            <TextBlock svc:Localized.Key="Common.Copy" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        x:Name="OpenDownloadLinkButton"
                                        Click="OpenDownloadLinkButton_Click"
                                        Style="{StaticResource ActionButtonStyle}"
                                        svc:Localized.ToolTipKey="Settings.Download.OpenTooltip">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="OpenFile" />
                                            <TextBlock svc:Localized.Key="Common.Open" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </toolkit:SettingsCard>

                        <toolkit:SettingsCard
                            HorizontalContentAlignment="Right"
                            svc:Localized.DescriptionKey="Settings.About.Description"
                            svc:Localized.HeaderKey="Settings.About.ReasonTitle">
                            <toolkit:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE946;" />
                            </toolkit:SettingsCard.HeaderIcon>
                            <Button
                                Click="ShowProductReasonButton_Click"
                                Style="{StaticResource ActionButtonStyle}"
                                svc:Localized.ToolTipKey="Settings.About.ReasonTitle">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="14" Glyph="&#xE946;" />
                                    <TextBlock svc:Localized.Key="Common.View" />
                                </StackPanel>
                            </Button>
                        </toolkit:SettingsCard>

                        <toolkit:SettingsCard
                            Description="{Binding OpenSourceRepositoryDisplayText}"
                            HorizontalContentAlignment="Right"
                            svc:Localized.HeaderKey="Settings.About.Repository">
                            <toolkit:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8A7;" />
                            </toolkit:SettingsCard.HeaderIcon>
                            <Button
                                Click="OpenRepositoryButton_Click"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTipService.ToolTip="{Binding OpenSourceRepositoryUrl}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="OpenFile" />
                                    <TextBlock svc:Localized.Key="Common.Open" />
                                </StackPanel>
                            </Button>
                        </toolkit:SettingsCard>

                        <toolkit:SettingsCard
                            HorizontalContentAlignment="Right"
                            svc:Localized.DescriptionKey="Settings.About.WechatDescription"
                            svc:Localized.HeaderKey="Settings.About.WechatTitle">
                            <toolkit:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8BD;" />
                            </toolkit:SettingsCard.HeaderIcon>
                            <Image
                                Source="ms-appx:///Assets/wechat-qrcode.jpg"
                                Width="100"
                                Height="100"
                                Stretch="Uniform"
                                VerticalAlignment="Center" />
                        </toolkit:SettingsCard>
                    </StackPanel>
                </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
