                            <ComboBox
                                MinWidth="176"
                                ItemsSource="{Binding AvailableFileStackThresholdDisplayNames}"
                                SelectedIndex="{Binding SelectedFileStackThresholdIndex, Mode=OneWay}"
                                SelectionChanged="SettingsComboBox_SelectionChanged"
                                Tag="FileStackThreshold" />
                        </toolkit:SettingsCard>

                        <toolkit:SettingsCard
                            HorizontalContentAlignment="Right"
                            IsEnabled="{Binding FileStacksEnabled}"
                            svc:Localized.DescriptionKey="Settings.FileStacks.OrderBy.Description"
                            svc:Localized.HeaderKey="Settings.FileStacks.OrderBy.Title">
                            <ComboBox
                                MinWidth="176"
                                ItemsSource="{Binding AvailableFileStackOrderByDisplayNames}"
                                SelectedIndex="{Binding SelectedFileStackOrderByIndex, Mode=OneWay}"
