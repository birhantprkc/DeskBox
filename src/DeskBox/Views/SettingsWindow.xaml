<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DeskBox.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:DeskBox.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="DeskBox Settings">

    <Grid
        x:Name="SettingsRoot"
        MinWidth="600"
        MinHeight="560"
        IsTabStop="True"
        Background="Transparent">
        <Grid.Resources>
            <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="PageDescriptionTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="SectionPanelStyle" TargetType="StackPanel">
                <Setter Property="Spacing" Value="10" />
            </Style>

            <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="SettingsGroupStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style x:Key="SettingRowStyle" TargetType="Grid">
                <Setter Property="Tag" Value="SettingRow" />
                <Setter Property="MinHeight" Value="66" />
                <Setter Property="Padding" Value="16,12" />
                <Setter Property="ColumnSpacing" Value="24" />
                <Setter Property="RowSpacing" Value="8" />
            </Style>

            <Style x:Key="SettingTextPanelStyle" TargetType="StackPanel">
                <Setter Property="Spacing" Value="3" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="SettingTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="SettingDescriptionTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="SettingValueTextStyle" TargetType="TextBlock" BasedOn="{StaticResource SettingDescriptionTextStyle}">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="SettingDividerStyle" TargetType="Border">
                <Setter Property="Height" Value="1" />
                <Setter Property="Margin" Value="16,0,0,0" />
                <Setter Property="Background" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
                <Setter Property="Opacity" Value="0.72" />
            </Style>

            <Style x:Key="InlineDropDownButtonStyle" TargetType="DropDownButton">
                <Setter Property="MinWidth" Value="176" />
                <Setter Property="MaxWidth" Value="260" />
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="Height" Value="34" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="12,0,10,0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>

            <Style x:Key="InlineNumberTextBoxStyle" TargetType="TextBox">
                <Setter Property="Width" Value="128" />
                <Setter Property="MinWidth" Value="128" />
                <Setter Property="MaxWidth" Value="128" />
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="Height" Value="32" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="10,4,10,5" />
                <Setter Property="TextAlignment" Value="Left" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <SolidColorBrush x:Key="SliderOuterThumbBackground" Color="Transparent" />
            <SolidColorBrush x:Key="SliderThumbBorderBrush" Color="Transparent" />
            <CornerRadius x:Key="SliderThumbCornerRadius">8</CornerRadius>
            <x:Double x:Key="SliderHorizontalThumbWidth">16</x:Double>
            <x:Double x:Key="SliderHorizontalThumbHeight">16</x:Double>
            <x:Double x:Key="SliderVerticalThumbWidth">16</x:Double>
            <x:Double x:Key="SliderVerticalThumbHeight">16</x:Double>
            <x:Double x:Key="SliderInnerThumbWidth">16</x:Double>
            <x:Double x:Key="SliderInnerThumbHeight">16</x:Double>

            <Style x:Key="InlineMetricSliderStyle" TargetType="Slider" BasedOn="{StaticResource DefaultSliderStyle}">
                <Setter Property="MinWidth" Value="180" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="IsThumbToolTipEnabled" Value="False" />
            </Style>

            <Style x:Key="ActionButtonStyle" TargetType="Button">
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="Height" Value="34" />
                <Setter Property="MinWidth" Value="104" />
                <Setter Property="Padding" Value="12,0" />
                <Setter Property="CornerRadius" Value="6" />
            </Style>

            <Style x:Key="SettingToggleSwitchStyle" TargetType="ToggleSwitch">
                <Setter Property="Width" Value="44" />
                <Setter Property="MinWidth" Value="44" />
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="OffContent" Value="" />
                <Setter Property="OnContent" Value="" />
            </Style>

            <Style x:Key="AccentSwatchButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="26" />
                <Setter Property="Height" Value="26" />
                <Setter Property="MinWidth" Value="26" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="13" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="Background" Value="Transparent" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Padding="18,0,128,0"
            Background="Transparent">
            <StackPanel
                x:Name="TitleTextHost"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <Image
                    Width="18"
                    Height="18"
                    VerticalAlignment="Center"
                    Source="ms-appx:///Assets/deskbox.svg" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="DeskBox" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="13"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    svc:Localized.Key="Settings.Title" />
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="0"
            Height="1"
            VerticalAlignment="Bottom"
            Background="{ThemeResource DividerStrokeColorDefaultBrush}"
            Opacity="0.18" />

        <ScrollViewer
            x:Name="PageScroller"
            Grid.Row="1"
            Padding="20,16,20,38"
            HorizontalContentAlignment="Stretch"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel
                x:Name="ContentHost"
                Width="720"
                MaxWidth="720"
                HorizontalAlignment="Center"
                Spacing="24">
                <StackPanel Style="{StaticResource SectionPanelStyle}">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" svc:Localized.Key="Settings.Section.Appearance" />
                    <Border Style="{StaticResource SettingsGroupStyle}">
                        <StackPanel>
                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.Theme.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.Theme.Description" />
                                </StackPanel>
                                <DropDownButton
                                    x:Name="ThemeDropDownButton"
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Click="SettingsDropDownButton_Click"
                                    Content="{Binding SelectedThemeText}"
                                    Style="{StaticResource InlineDropDownButtonStyle}"
                                    Tag="Theme" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.Language.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.Language.Description" />
                                </StackPanel>
                                <DropDownButton
                                    x:Name="LanguageDropDownButton"
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Click="SettingsDropDownButton_Click"
                                    Content="{Binding SelectedLanguageText}"
                                    Style="{StaticResource InlineDropDownButtonStyle}"
                                    Tag="Language" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.SystemAccent.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.SystemAccent.Description" />
                                </StackPanel>
                                <ToggleSwitch
                                    Grid.Column="1"
                                    IsOn="{Binding UseSystemAccentColor, Mode=TwoWay}"
                                    Style="{StaticResource SettingToggleSwitchStyle}" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.Accent.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding AccentColorDescription}" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Orientation="Vertical"
                                    Spacing="8">
                                    <Button
                                        HorizontalAlignment="Right"
                                        Click="AccentColorButton_Click"
                                        IsEnabled="{Binding CanEditCustomAccent}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        svc:Localized.ToolTipKey="Settings.Accent.Tooltip">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border
                                                Width="16"
                                                Height="16"
                                                VerticalAlignment="Center"
                                                Background="{Binding AccentPreviewBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8" />
                                            <TextBlock VerticalAlignment="Center" Text="{Binding AccentColorHex}" />
                                        </StackPanel>
                                    </Button>
                                    <StackPanel
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal"
                                        Spacing="6">
                                        <Button
                                            Click="AccentPresetButton_Click"
                                            Style="{StaticResource AccentSwatchButtonStyle}"
                                            Tag="#0078D4"
                                            ToolTipService.ToolTip="#0078D4">
                                            <Border Width="16" Height="16" Background="#0078D4" CornerRadius="8" />
                                        </Button>
                                        <Button
                                            Click="AccentPresetButton_Click"
                                            Style="{StaticResource AccentSwatchButtonStyle}"
                                            Tag="#EF6950"
                                            ToolTipService.ToolTip="#EF6950">
                                            <Border Width="16" Height="16" Background="#EF6950" CornerRadius="8" />
                                        </Button>
                                        <Button
                                            Click="AccentPresetButton_Click"
                                            Style="{StaticResource AccentSwatchButtonStyle}"
                                            Tag="#2D7D46"
                                            ToolTipService.ToolTip="#2D7D46">
                                            <Border Width="16" Height="16" Background="#2D7D46" CornerRadius="8" />
                                        </Button>
                                        <Button
                                            Click="AccentPresetButton_Click"
                                            Style="{StaticResource AccentSwatchButtonStyle}"
                                            Tag="#8764B8"
                                            ToolTipService.ToolTip="#8764B8">
                                            <Border Width="16" Height="16" Background="#8764B8" CornerRadius="8" />
                                        </Button>
                                        <Button
                                            Click="AccentPresetButton_Click"
                                            Style="{StaticResource AccentSwatchButtonStyle}"
                                            Tag="#D83B01"
                                            ToolTipService.ToolTip="#D83B01">
                                            <Border Width="16" Height="16" Background="#D83B01" CornerRadius="8" />
                                        </Button>
                                        <Button
                                            Click="AccentPresetButton_Click"
                                            Style="{StaticResource AccentSwatchButtonStyle}"
                                            Tag="#038387"
                                            ToolTipService.ToolTip="#038387">
                                            <Border Width="16" Height="16" Background="#038387" CornerRadius="8" />
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Style="{StaticResource SectionPanelStyle}">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" svc:Localized.Key="Settings.Section.WidgetDefaults" />
                    <Border Style="{StaticResource SettingsGroupStyle}">
                        <StackPanel>
                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.DefaultWidth.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.DefaultWidth.Description" />
                                </StackPanel>
                                <TextBox
                                    Grid.Column="1"
                                    GotFocus="EditableSettingsTextBox_GotFocus"
                                    InputScope="Number"
                                    KeyDown="EditableSettingsTextBox_KeyDown"
                                    Style="{StaticResource InlineNumberTextBoxStyle}"
                                    Text="{Binding DefaultWidthInput, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.DefaultHeight.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.DefaultHeight.Description" />
                                </StackPanel>
                                <TextBox
                                    Grid.Column="1"
                                    GotFocus="EditableSettingsTextBox_GotFocus"
                                    InputScope="Number"
                                    KeyDown="EditableSettingsTextBox_KeyDown"
                                    Style="{StaticResource InlineNumberTextBoxStyle}"
                                    Text="{Binding DefaultHeightInput, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Style="{StaticResource SectionPanelStyle}">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" svc:Localized.Key="Settings.Section.DisplayDensity" />
                    <Border Style="{StaticResource SettingsGroupStyle}">
                        <StackPanel>
                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.Corner.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.Corner.Description" />
                                </StackPanel>
                                <DropDownButton
                                    x:Name="WidgetCornerDropDownButton"
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Click="SettingsDropDownButton_Click"
                                    Content="{Binding SelectedWidgetCornerPreferenceText}"
                                    Style="{StaticResource InlineDropDownButtonStyle}"
                                    Tag="WidgetCorner" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.Animation.Effect.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.Animation.Effect.Description" />
                                </StackPanel>
                                <DropDownButton
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Click="SettingsDropDownButton_Click"
                                    Content="{Binding SelectedWidgetAnimationEffectText}"
                                    Style="{StaticResource InlineDropDownButtonStyle}"
                                    Tag="WidgetAnimationEffect" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.Animation.Speed.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.Animation.Speed.Description" />
                                </StackPanel>
                                <DropDownButton
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Click="SettingsDropDownButton_Click"
                                    Content="{Binding SelectedWidgetAnimationSpeedText}"
                                    Style="{StaticResource InlineDropDownButtonStyle}"
                                    Tag="WidgetAnimationSpeed" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid
                                Padding="16,14"
                                ColumnSpacing="16"
                                RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="176" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.Opacity.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding WidgetOpacityValueText}" />
                                </StackPanel>
                                <Slider
                                    Grid.Column="1"
                                    Maximum="1"
                                    Minimum="0"
                                    StepFrequency="0.02"
                                    Style="{StaticResource InlineMetricSliderStyle}"
                                    Value="{Binding WidgetOpacity, Mode=TwoWay}"
                                    ManipulationMode="TranslateX"
                                    ManipulationStarted="AppearanceSlider_ManipulationStarted"
                                    ManipulationCompleted="AppearanceSlider_ManipulationCompleted"
                                    ValueChanged="AppearanceSlider_ValueChanged"
                                    PointerPressed="AppearanceSlider_PointerPressed"
                                    PointerReleased="AppearanceSlider_PointerReleased"
                                    LostFocus="AppearanceSlider_LostFocus" />
                                <TextBox
                                    Grid.Column="2"
                                    GotFocus="EditableSettingsTextBox_GotFocus"
                                    InputScope="Number"
                                    KeyDown="EditableSettingsTextBox_KeyDown"
                                    Style="{StaticResource InlineNumberTextBoxStyle}"
                                    Text="{Binding WidgetOpacityPercentInput, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid
                                Padding="16,14"
                                ColumnSpacing="16"
                                RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="176" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.IconSize.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding IconSizeValueText}" />
                                </StackPanel>
                                <Slider
                                    Grid.Column="1"
                                    Maximum="56"
                                    Minimum="24"
                                    StepFrequency="2"
                                    Style="{StaticResource InlineMetricSliderStyle}"
                                    Value="{Binding IconSize, Mode=TwoWay}"
                                    ManipulationMode="TranslateX"
                                    ManipulationStarted="AppearanceSlider_ManipulationStarted"
                                    ManipulationCompleted="AppearanceSlider_ManipulationCompleted"
                                    ValueChanged="AppearanceSlider_ValueChanged"
                                    PointerPressed="AppearanceSlider_PointerPressed"
                                    PointerReleased="AppearanceSlider_PointerReleased"
                                    LostFocus="AppearanceSlider_LostFocus" />
                                <TextBox
                                    Grid.Column="2"
                                    GotFocus="EditableSettingsTextBox_GotFocus"
                                    InputScope="Number"
                                    KeyDown="EditableSettingsTextBox_KeyDown"
                                    Style="{StaticResource InlineNumberTextBoxStyle}"
                                    Text="{Binding IconSizeInput, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid
                                Padding="16,14"
                                ColumnSpacing="16"
                                RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="176" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.TextSize.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding TextSizeValueText}" />
                                </StackPanel>
                                <Slider
                                    Grid.Column="1"
                                    Maximum="16"
                                    Minimum="10"
                                    StepFrequency="0.5"
                                    Style="{StaticResource InlineMetricSliderStyle}"
                                    Value="{Binding TextSize, Mode=TwoWay}"
                                    ManipulationMode="TranslateX"
                                    ManipulationStarted="AppearanceSlider_ManipulationStarted"
                                    ManipulationCompleted="AppearanceSlider_ManipulationCompleted"
                                    ValueChanged="AppearanceSlider_ValueChanged"
                                    PointerPressed="AppearanceSlider_PointerPressed"
                                    PointerReleased="AppearanceSlider_PointerReleased"
                                    LostFocus="AppearanceSlider_LostFocus" />
                                <TextBox
                                    Grid.Column="2"
                                    GotFocus="EditableSettingsTextBox_GotFocus"
                                    InputScope="Number"
                                    KeyDown="EditableSettingsTextBox_KeyDown"
                                    Style="{StaticResource InlineNumberTextBoxStyle}"
                                    Text="{Binding TextSizeInput, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid
                                Padding="16,14"
                                ColumnSpacing="16"
                                RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="176" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.HorizontalSpacing.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding HorizontalSpacingValueText}" />
                                </StackPanel>
                                <Slider
                                    Grid.Column="1"
                                    Maximum="1"
                                    Minimum="0"
                                    StepFrequency="0.02"
                                    Style="{StaticResource InlineMetricSliderStyle}"
                                    Value="{Binding HorizontalSpacingScale, Mode=TwoWay}"
                                    ManipulationMode="TranslateX"
                                    ManipulationStarted="AppearanceSlider_ManipulationStarted"
                                    ManipulationCompleted="AppearanceSlider_ManipulationCompleted"
                                    ValueChanged="AppearanceSlider_ValueChanged"
                                    PointerPressed="AppearanceSlider_PointerPressed"
                                    PointerReleased="AppearanceSlider_PointerReleased"
                                    LostFocus="AppearanceSlider_LostFocus" />
                                <TextBox
                                    Grid.Column="2"
                                    GotFocus="EditableSettingsTextBox_GotFocus"
                                    InputScope="Number"
                                    KeyDown="EditableSettingsTextBox_KeyDown"
                                    Style="{StaticResource InlineNumberTextBoxStyle}"
                                    Text="{Binding HorizontalSpacingPercentInput, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid
                                Padding="16,14"
                                ColumnSpacing="16"
                                RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="176" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.VerticalSpacing.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding VerticalSpacingValueText}" />
                                </StackPanel>
                                <Slider
                                    Grid.Column="1"
                                    Maximum="1"
                                    Minimum="0"
                                    StepFrequency="0.02"
                                    Style="{StaticResource InlineMetricSliderStyle}"
                                    Value="{Binding VerticalSpacingScale, Mode=TwoWay}"
                                    ManipulationMode="TranslateX"
                                    ManipulationStarted="AppearanceSlider_ManipulationStarted"
                                    ManipulationCompleted="AppearanceSlider_ManipulationCompleted"
                                    ValueChanged="AppearanceSlider_ValueChanged"
                                    PointerPressed="AppearanceSlider_PointerPressed"
                                    PointerReleased="AppearanceSlider_PointerReleased"
                                    LostFocus="AppearanceSlider_LostFocus" />
                                <TextBox
                                    Grid.Column="2"
                                    GotFocus="EditableSettingsTextBox_GotFocus"
                                    InputScope="Number"
                                    KeyDown="EditableSettingsTextBox_KeyDown"
                                    Style="{StaticResource InlineNumberTextBoxStyle}"
                                    Text="{Binding VerticalSpacingPercentInput, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid
                                Padding="16,14"
                                ColumnSpacing="16"
                                RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="176" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.FileNameWidth.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding FileNameWidthValueText}" />
                                </StackPanel>
                                <Slider
                                    Grid.Column="1"
                                    Maximum="1"
                                    Minimum="0"
                                    StepFrequency="0.02"
                                    Style="{StaticResource InlineMetricSliderStyle}"
                                    Value="{Binding FileNameWidthScale, Mode=TwoWay}"
                                    ManipulationMode="TranslateX"
                                    ManipulationStarted="AppearanceSlider_ManipulationStarted"
                                    ManipulationCompleted="AppearanceSlider_ManipulationCompleted"
                                    ValueChanged="AppearanceSlider_ValueChanged"
                                    PointerPressed="AppearanceSlider_PointerPressed"
                                    PointerReleased="AppearanceSlider_PointerReleased"
                                    LostFocus="AppearanceSlider_LostFocus" />
                                <TextBox
                                    Grid.Column="2"
                                    GotFocus="EditableSettingsTextBox_GotFocus"
                                    InputScope="Number"
                                    KeyDown="EditableSettingsTextBox_KeyDown"
                                    Style="{StaticResource InlineNumberTextBoxStyle}"
                                    Text="{Binding FileNameWidthPercentInput, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Style="{StaticResource SectionPanelStyle}">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" svc:Localized.Key="Settings.Section.Storage" />
                    <Border Style="{StaticResource SettingsGroupStyle}">
                        <StackPanel>
                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.DropAction.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.DropAction.Description" />
                                </StackPanel>
                                <DropDownButton
                                    x:Name="ManagedDropActionDropDownButton"
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Click="SettingsDropDownButton_Click"
                                    Content="{Binding SelectedManagedDropActionText}"
                                    Style="{StaticResource InlineDropDownButtonStyle}"
                                    Tag="ManagedDropAction" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <StackPanel Padding="16,14" Spacing="12">
                                <StackPanel Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.ManagedPath.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.ManagedPath.Description" />
                                </StackPanel>
                                <TextBox
                                    IsReadOnly="True"
                                    Text="{Binding ManagedStorageRootPath, Mode=OneWay}"
                                    TextWrapping="NoWrap" />
                                <StackPanel
                                    x:Name="PathActionsPanel"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Button
                                        x:Name="OpenPathButton"
                                        Click="OpenManagedStoragePathButton_Click"
                                        Style="{StaticResource ActionButtonStyle}"
                                        svc:Localized.ToolTipKey="Settings.ManagedPath.OpenTooltip">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="OpenFile" />
                                            <TextBlock svc:Localized.Key="Common.Open" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        x:Name="ChangePathButton"
                                        Click="ChangeManagedStoragePathButton_Click"
                                        Style="{StaticResource ActionButtonStyle}"
                                        svc:Localized.ToolTipKey="Settings.ManagedPath.ChangeTooltip">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Folder" />
                                            <TextBlock svc:Localized.Key="Common.Change" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        x:Name="CleanupStorageButton"
                                        Click="CleanupManagedStorageButton_Click"
                                        Style="{StaticResource ActionButtonStyle}"
                                        svc:Localized.ToolTipKey="Settings.ManagedPath.CleanupTooltip">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Delete" />
                                            <TextBlock svc:Localized.Key="Common.Cleanup" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Style="{StaticResource SectionPanelStyle}">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" svc:Localized.Key="Settings.Section.Interaction" />
                    <Border Style="{StaticResource SettingsGroupStyle}">
                        <StackPanel>
                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.DoubleClick.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.DoubleClick.Description" />
                                </StackPanel>
                                <ToggleSwitch
                                    Grid.Column="1"
                                    IsOn="{Binding DoubleClickToOpen, Mode=TwoWay}"
                                    Style="{StaticResource SettingToggleSwitchStyle}" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.HideShortcutArrow.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.HideShortcutArrow.Description" />
                                </StackPanel>
                                <ToggleSwitch
                                    Grid.Column="1"
                                    IsOn="{Binding HideShortcutArrowOverlay, Mode=TwoWay}"
                                    Style="{StaticResource SettingToggleSwitchStyle}" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.ListDetails.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.ListDetails.Description" />
                                </StackPanel>
                                <ToggleSwitch
                                    Grid.Column="1"
                                    IsOn="{Binding ShowListItemDetails, Mode=TwoWay}"
                                    Style="{StaticResource SettingToggleSwitchStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Style="{StaticResource SectionPanelStyle}">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" svc:Localized.Key="Settings.Section.System" />
                    <Border Style="{StaticResource SettingsGroupStyle}">
                        <StackPanel>
                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.AutoStart.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.AutoStart.Description" />
                                </StackPanel>
                                <ToggleSwitch
                                    Grid.Column="1"
                                    IsOn="{Binding AutoStart, Mode=TwoWay}"
                                    Style="{StaticResource SettingToggleSwitchStyle}" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.Onboarding.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.Onboarding.Description" />
                                </StackPanel>
                                <Button
                                    Grid.Column="1"
                                    Click="ShowOnboardingButton_Click"
                                    Style="{StaticResource ActionButtonStyle}"
                                    svc:Localized.ToolTipKey="Settings.Onboarding.Tooltip">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="14" Glyph="&#xE82D;" />
                                        <TextBlock svc:Localized.Key="Common.View" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.Restore.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.Restore.Description" />
                                </StackPanel>
                                <Button
                                    Grid.Column="1"
                                    Click="RestoreDefaultSettingsButton_Click"
                                    Style="{StaticResource ActionButtonStyle}"
                                    svc:Localized.ToolTipKey="Settings.Restore.Tooltip">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="Refresh" />
                                        <TextBlock svc:Localized.Key="Common.Restore" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Style="{StaticResource SectionPanelStyle}">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" svc:Localized.Key="Settings.Section.About" />
                    <Border Style="{StaticResource SettingsGroupStyle}">
                        <StackPanel>
                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" Text="DeskBox" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.About.Description" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource SettingValueTextStyle}"
                                    Text="{Binding AboutVersionText}" />
                            </Grid>

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.About.ReasonTitle" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.About.Description" />
                                </StackPanel>
                                <Button
                                    Grid.Column="1"
                                    Click="ShowProductReasonButton_Click"
                                    Style="{StaticResource ActionButtonStyle}"
                                    svc:Localized.ToolTipKey="Settings.About.ReasonTitle">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="14" Glyph="&#xE946;" />
                                        <TextBlock svc:Localized.Key="Common.View" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.About.Repository" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding OpenSourceRepositoryDisplayText}" />
                                </StackPanel>
                                <Button
                                    Grid.Column="1"
                                    Click="OpenRepositoryButton_Click"
                                    Style="{StaticResource ActionButtonStyle}"
                                    ToolTipService.ToolTip="{Binding OpenSourceRepositoryUrl}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="OpenFile" />
                                        <TextBlock svc:Localized.Key="Common.Open" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
