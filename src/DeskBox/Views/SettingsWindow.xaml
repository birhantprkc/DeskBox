                                                                IsEnabled="{Binding CanMoveUp}"
                                                                Style="{StaticResource IconActionButtonStyle}"
                                                                svc:Localized.ToolTipKey="Settings.FileStacks.Custom.MoveUp">
                                                                <FontIcon FontSize="12" Glyph="&#xE70E;" />
                                                            </Button>
                                                            <Button
                                                                Click="MoveFileStackRuleDownButton_Click"
                                                                IsEnabled="{Binding CanMoveDown}"
                                                                Style="{StaticResource IconActionButtonStyle}"
                                                                svc:Localized.ToolTipKey="Settings.FileStacks.Custom.MoveDown">
                                                                <FontIcon FontSize="12" Glyph="&#xE70D;" />
                                                            </Button>
                                                            <Button
                                                                Click="RemoveFileStackRuleButton_Click"
                                                                Style="{StaticResource IconActionButtonStyle}"
                                                                svc:Localized.ToolTipKey="Settings.FileStacks.Custom.Remove">
                                                                <FontIcon FontSize="12" Glyph="&#xE74D;" />
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                    <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="2*,3*" ColumnSpacing="10">
                                                        <TextBox
                                                            Grid.Column="0"
                                                            MaxLength="80"
                                                            Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            svc:Localized.HeaderKey="Settings.FileStacks.Custom.Name" />
                                                        <TextBox
                                                            Grid.Column="1"
                                                            PlaceholderText=".psd .ai .fig"
                                                            Text="{Binding ExtensionsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            svc:Localized.HeaderKey="Settings.FileStacks.Custom.Extensions" />
                                                    </Grid>
                                                    <TextBlock
                                                        Grid.Row="2"
                                                        Grid.Column="1"
                                                        Style="{StaticResource SettingDescriptionTextStyle}"
                                                        Text="{Binding PreviewText}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Opacity="0.35" />
                                    <TextBlock
                                        Style="{StaticResource SettingDescriptionTextStyle}"
                                        Text="{Binding FileStackPreviewSummaryText}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

