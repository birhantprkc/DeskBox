                                    Click="OpenManagedStoragePathButton_Click"
                                    Style="{StaticResource IconActionButtonStyle}"
                                    VerticalAlignment="Center"
                                    svc:Localized.ToolTipKey="Settings.ManagedPath.OpenTooltip">
                                    <SymbolIcon Symbol="OpenFile" />
                                </Button>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="FileDisplaySettingsSection" Visibility="Collapsed" Style="{StaticResource SectionPanelStyle}">
                    <StackPanel Margin="0,8,0,0" Spacing="4">
                        <toolkit:SettingsCard HorizontalContentAlignment="Right" svc:Localized.DescriptionKey="Settings.ShowFileExtensions.Description" svc:Localized.HeaderKey="Settings.ShowFileExtensions.Title">
                            <toolkit:SettingsCard.HeaderIcon><FontIcon Glyph="&#xE8D2;" /></toolkit:SettingsCard.HeaderIcon>
                            <ToggleSwitch OnContent="" OffContent="" MinWidth="0" IsOn="{Binding ShowFileExtensions, Mode=TwoWay}" />
                        </toolkit:SettingsCard>
                        <toolkit:SettingsCard HorizontalContentAlignment="Right" svc:Localized.DescriptionKey="Settings.HideShortcutExtension.Description" svc:Localized.HeaderKey="Settings.HideShortcutExtension.Title">
                            <ToggleSwitch OnContent="" OffContent="" MinWidth="0" IsEnabled="{Binding ShowFileExtensions}" IsOn="{Binding HideShortcutExtensionWhenShowingFileExtensions, Mode=TwoWay}" />
                        </toolkit:SettingsCard>
                        <toolkit:SettingsCard HorizontalContentAlignment="Right" svc:Localized.DescriptionKey="Settings.ShowImageFilesAsIcons.Description" svc:Localized.HeaderKey="Settings.ShowImageFilesAsIcons.Title">
                            <ToggleSwitch OnContent="" OffContent="" MinWidth="0" IsOn="{Binding ShowImageFilesAsIcons, Mode=TwoWay}" />
                        </toolkit:SettingsCard>
                        <toolkit:SettingsCard HorizontalContentAlignment="Right" svc:Localized.DescriptionKey="Settings.HideShortcutArrow.Description" svc:Localized.HeaderKey="Settings.HideShortcutArrow.Title">
                            <ToggleSwitch OnContent="" OffContent="" MinWidth="0" IsOn="{Binding HideShortcutArrowOverlay, Mode=TwoWay}" />
                        </toolkit:SettingsCard>
                        <toolkit:SettingsCard HorizontalContentAlignment="Right" svc:Localized.DescriptionKey="Settings.ListDetails.Description" svc:Localized.HeaderKey="Settings.ListDetails.Title">
                            <ToggleSwitch OnContent="" OffContent="" MinWidth="0" IsOn="{Binding ShowListItemDetails, Mode=TwoWay}" />
