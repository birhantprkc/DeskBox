                            <Border Style="{StaticResource SettingsGroupStyle}">
                                <StackPanel Padding="16,14" Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0" Spacing="3">
                                            <TextBlock
                                                Style="{StaticResource SettingTitleTextStyle}"
                                                svc:Localized.Key="Settings.FileStacks.Custom.Rules.Title" />
