                                    SelectedIndex="{Binding SelectedFileStackUnmatchedBehaviorIndex, Mode=OneWay}"
                                    SelectionChanged="SettingsComboBox_SelectionChanged"
                                    Tag="FileStackUnmatchedBehavior" />
