                                    </Button>
                                    <Button x:Name="ChangePathButton" Click="ChangeManagedStoragePathButton_Click" Style="{StaticResource ActionButtonStyle}" svc:Localized.ToolTipKey="Settings.ManagedPath.ChangeTooltip">
                                        <StackPanel Orientation="Horizontal" Spacing="8"><SymbolIcon Symbol="Folder" /><TextBlock svc:Localized.Key="Common.Change" /></StackPanel>
                                    </Button>
                                    <Button x:Name="CleanupStorageButton" Click="CleanupManagedStorageButton_Click" Style="{StaticResource ActionButtonStyle}" svc:Localized.ToolTipKey="Settings.ManagedStorage.ManageTooltip">
                                        <StackPanel Orientation="Horizontal" Spacing="8"><SymbolIcon Symbol="Setting" /><TextBlock svc:Localized.Key="Settings.ManagedStorage.Manage" /></StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </toolkit:SettingsCard>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="FileStackSettingsSection"
                    Visibility="Collapsed"
                    Style="{StaticResource SectionPanelStyle}">
