<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DeskBox.Views.OnboardingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:DeskBox.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="DeskBox Onboarding">

    <Grid
        x:Name="RootGrid"
        MinWidth="720"
        MinHeight="520"
        Padding="48"
        Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarHost" Height="36" Margin="-48,-48,-48,8" Background="Transparent" />

        <Grid Grid.Row="1" ColumnSpacing="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Column="0"
                MaxWidth="430"
                VerticalAlignment="Center"
                Spacing="18">
                <Image
                    Width="36"
                    Height="36"
                    HorizontalAlignment="Left"
                    Source="ms-appx:///Assets/deskbox.svg" />

                <StackPanel Spacing="10">
                    <TextBlock
                        x:Name="StepEyebrowText"
                        FontSize="13"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        svc:Localized.Key="Onboarding.Step1.Eyebrow" />
                    <TextBlock
                        x:Name="StepTitleText"
                        FontSize="34"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        LineHeight="40"
                        svc:Localized.Key="Onboarding.Step1.Title"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="StepBodyText"
                        MaxWidth="400"
                        FontSize="15"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        LineHeight="24"
                        svc:Localized.Key="Onboarding.Step1.Body"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <StackPanel
                    x:Name="StepHintPanel"
                    Spacing="8" />

                <StackPanel
                    x:Name="StepOptionPanel"
                    Margin="0,4,0,0"
                    Spacing="10" />
            </StackPanel>

            <Grid
                Grid.Column="1"
                MinHeight="360"
                VerticalAlignment="Center">
                <Border
                    x:Name="DemoDesktop"
                    Width="320"
                    Height="250"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <Canvas
                            x:Name="DemoScene"
                            Width="320"
                            Height="250"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Margin="0,32,0,0">
            <StackPanel
                x:Name="ProgressDots"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8" />

            <StackPanel
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    x:Name="SkipButton"
                    MinWidth="88"
                    Click="SkipButton_Click"
                    svc:Localized.Key="Onboarding.Skip" />
                <Button
                    x:Name="BackButton"
                    MinWidth="88"
                    Click="BackButton_Click"
                    svc:Localized.Key="Onboarding.Back" />
                <Button
                    x:Name="NextButton"
                    MinWidth="96"
                    Click="NextButton_Click"
                    Style="{ThemeResource AccentButtonStyle}"
                    svc:Localized.Key="Onboarding.Next" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
