<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DeskBox.Views.OnboardingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:DeskBox.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="DeskBox Onboarding">

    <Grid
        x:Name="RootGrid"
        MinWidth="560"
        MinHeight="440"
        Padding="48"
        Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarHost" Height="36" Margin="-48,-48,-48,8" Background="Transparent" />

        <ScrollViewer
            x:Name="ContentScrollViewer"
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto">
            <Grid
                x:Name="MainContentGrid"
                Opacity="0"
                ColumnSpacing="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    x:Name="StepContentPanel"
                    Grid.Column="0"
                    MaxWidth="430"
                    VerticalAlignment="Center"
                    Spacing="18">
                    <Grid
                        x:Name="BrandLogoHost"
                        Width="36"
                        Height="36"
                        HorizontalAlignment="Left"
                        Opacity="0">
                        <Grid.Clip>
                            <RectangleGeometry Rect="0,0,36,36" />
                        </Grid.Clip>
                        <Image
                            x:Name="BrandLogo"
                            Width="36"
                            Height="36"
                            Source="ms-appx:///Assets/deskbox.svg" />
                        <Border
                            x:Name="BrandLogoShine"
                            Width="14"
                            Height="54"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False"
                            Opacity="0.36"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="#00FFFFFF" />
                                    <GradientStop Offset="0.5" Color="#A6FFFFFF" />
                                    <GradientStop Offset="1" Color="#00FFFFFF" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.RenderTransform>
                                <CompositeTransform
                                    x:Name="BrandLogoShineTransform"
                                    Rotation="-18"
                                    TranslateX="-44" />
                            </Border.RenderTransform>
                        </Border>
                    </Grid>

                <StackPanel Spacing="10">
                    <TextBlock
                        x:Name="StepEyebrowText"
                        FontSize="13"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        svc:Localized.Key="Onboarding.Step1.Eyebrow" />
                    <TextBlock
                        x:Name="StepTitleText"
                        FontSize="34"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        LineHeight="40"
                        svc:Localized.Key="Onboarding.Step1.Title"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="StepBodyText"
                        MaxWidth="400"
                        FontSize="15"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        LineHeight="24"
                        svc:Localized.Key="Onboarding.Step1.Body"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <StackPanel
                    x:Name="StepHintPanel"
                    Spacing="8" />

                <StackPanel
                    x:Name="StepOptionPanel"
                    Margin="0,4,0,0"
                    Spacing="10" />
                </StackPanel>

                <Grid
                    x:Name="DemoSceneHost"
                    Grid.Column="1"
                    MinHeight="360"
                    VerticalAlignment="Center">
                    <Border
                        x:Name="DemoDesktop"
                        Width="320"
                        Height="250"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid>
                            <Canvas
                                x:Name="DemoScene"
                                Width="320"
                                Height="250"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Grid
            x:Name="FooterNav"
            Grid.Row="2"
            Opacity="0"
            Margin="0,32,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel
                x:Name="ProgressDots"
                Grid.Row="0"
                Grid.Column="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8" />

            <StackPanel
                x:Name="FooterButtons"
                Grid.Row="0"
                Grid.Column="1"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    x:Name="SkipButton"
                    MinWidth="88"
                    Click="SkipButton_Click"
                    svc:Localized.Key="Onboarding.Skip" />
                <Button
                    x:Name="BackButton"
                    MinWidth="88"
                    Click="BackButton_Click"
                    svc:Localized.Key="Onboarding.Back" />
                <Button
                    x:Name="NextButton"
                    MinWidth="96"
                    Click="NextButton_Click"
                    Style="{ThemeResource AccentButtonStyle}"
                    svc:Localized.Key="Onboarding.Next" />
            </StackPanel>
        </Grid>

        <Grid
            x:Name="IntroOverlay"
            Grid.RowSpan="3"
            Margin="-48"
            Padding="48"
            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
            IsHitTestVisible="False">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="18">
                <Canvas
                    x:Name="IntroMarkHost"
                    Width="170"
                    Height="170"
                    HorizontalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5" />
                <StackPanel Spacing="8">
                    <TextBlock
                        x:Name="IntroTitleText"
                        HorizontalAlignment="Center"
                        FontSize="32"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        TextAlignment="Center" />
                    <TextBlock
                        x:Name="IntroBodyText"
                        Width="420"
                        FontSize="15"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        LineHeight="24"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
