<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DeskBox.Views.QuickCaptureWidgetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="DeskBox Quick Capture">

    <Grid
        x:Name="RootGrid"
        Background="Transparent"
        IsTabStop="True"
        KeyDown="RootGrid_KeyDown"
        PointerEntered="RootGrid_PointerEntered"
        PointerExited="RootGrid_PointerExited"
        AllowDrop="True"
        DragOver="RootGrid_DragOver"
        Drop="RootGrid_Drop">
        <Grid.Resources>
            <Style x:Key="QuickCaptureIconButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="26" />
                <Setter Property="Height" Value="26" />
                <Setter Property="MinWidth" Value="26" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="6" />
            </Style>

            <Style x:Key="QuickCaptureItemActionButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="26" />
                <Setter Property="Height" Value="26" />
                <Setter Property="MinWidth" Value="26" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{ThemeResource ButtonBackground}" />
                <Setter Property="BorderBrush" Value="{ThemeResource ButtonBorderBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource ButtonForeground}" />
            </Style>

            <Style x:Key="QuickCaptureItemButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
            </Style>

            <Style x:Key="QuickCaptureSegmentButtonStyle" TargetType="Button">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="24" />
                <Setter Property="Height" Value="24" />
                <Setter Property="Padding" Value="4,0" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <Style x:Key="QuickCaptureTabButtonStyle" TargetType="Button" BasedOn="{StaticResource QuickCaptureSegmentButtonStyle}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                                <ContentPresenter
                                    Padding="{TemplateBinding Padding}"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            x:Name="BackgroundPlate"
            Grid.RowSpan="2"
            BorderThickness="0"
            CornerRadius="0" />

        <Grid
            x:Name="TitleBarGrid"
            Grid.Row="0"
            Padding="14,7,12,5"
            Background="Transparent"
            RightTapped="TitleBarGrid_RightTapped"
            PointerPressed="TitleBarGrid_PointerPressed"
            PointerMoved="TitleBarGrid_PointerMoved"
            PointerReleased="TitleBarGrid_PointerReleased">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <FontIcon
                    x:Name="TitleIcon"
                    FontSize="{Binding TitleIconSize}"
                    Glyph="&#xE8A5;" />
                <TextBlock
                    x:Name="TitleText"
                    FontSize="{Binding TitleTextSize}"
                    Text="{Binding Name}"
                    TextTrimming="CharacterEllipsis"
                    VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel
                x:Name="RightActionButtons"
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="4"
                Opacity="0"
                VerticalAlignment="Center">
                <Button
                    x:Name="MoreButton"
                    Width="22"
                    Height="22"
                    Padding="0"
                    Click="MoreButton_Click"
                    >
                    <FontIcon x:Name="MoreButtonIcon" FontSize="11" Glyph="&#xE712;" />
                </Button>
                <Button
                    x:Name="CloseButton"
                    Width="22"
                    Height="22"
                    Padding="0"
                    Click="CloseButton_Click"
                    >
                    <FontIcon x:Name="CloseButtonIcon" FontSize="11" Glyph="&#xE74D;" />
                </Button>
            </StackPanel>
        </Grid>

        <Border
            x:Name="HeaderDivider"
            Grid.Row="0"
            Height="1"
            Margin="12,0"
            VerticalAlignment="Bottom" />

        <Grid Grid.Row="1" Padding="10,6,6,8" RowSpacing="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="InputTextBox"
                    Grid.Column="0"
                    Height="{Binding IconSize}"
                    MinHeight="28"
                    Padding="8,4,8,0"
                    FontSize="{Binding TextSize}"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"
                    Text="{Binding InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap"
                    KeyDown="InputTextBox_KeyDown" />
                <Button
                    x:Name="AddInputButton"
                    Grid.Column="1"
                    Click="AddButton_Click"
                    Width="{Binding IconSize}"
                    Height="{Binding IconSize}"
                    MinWidth="{Binding IconSize}"
                    IsEnabled="{Binding CanAddInput}"
                    Style="{StaticResource QuickCaptureIconButtonStyle}">
                    <FontIcon FontSize="{Binding ActionIconSize}" Glyph="&#xE710;" />
                </Button>
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid
                    x:Name="TabHost"
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    SizeChanged="TabHost_SizeChanged"
                    Visibility="{Binding SearchButtonVisibility}">
                    <Border
                        x:Name="TabSelectionIndicator"
                        Width="58"
                        Height="24"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        BorderThickness="1"
                        CornerRadius="6"
                        IsHitTestVisible="False"
                        Opacity="0" />
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="3">
                        <Button
                            x:Name="RecordsTabButton"
                            Click="RecordsTabButton_Click"
                            PointerEntered="RecordsTabButton_PointerEntered"
                            PointerExited="TabButton_PointerExited"
                            Width="58"
                            FontSize="{Binding SegmentTextSize}"
                            Style="{StaticResource QuickCaptureTabButtonStyle}">
                            <TextBlock
                                Text="{Binding RecordsTabText}"
                                TextAlignment="Center"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap" />
                        </Button>
                        <Button
                            x:Name="PinnedTabButton"
                            Click="PinnedTabButton_Click"
                            PointerEntered="PinnedTabButton_PointerEntered"
                            PointerExited="TabButton_PointerExited"
                            Width="58"
                            FontSize="{Binding SegmentTextSize}"
                            Style="{StaticResource QuickCaptureTabButtonStyle}">
                            <TextBlock
                                Text="{Binding PinnedTabText}"
                                TextAlignment="Center"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap" />
                        </Button>
                        <Button
                            x:Name="RecentTabButton"
                            Click="RecentTabButton_Click"
                            PointerEntered="RecentTabButton_PointerEntered"
                            PointerExited="TabButton_PointerExited"
                            Width="58"
                            FontSize="{Binding SegmentTextSize}"
                            Style="{StaticResource QuickCaptureTabButtonStyle}">
                            <TextBlock
                                Text="{Binding RecentTabText}"
                                TextAlignment="Center"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap" />
                        </Button>
                    </StackPanel>
                </Grid>
                <Button
                    x:Name="SearchButton"
                    Grid.Column="1"
                    Click="SearchButton_Click"
                    Width="{Binding IconSize}"
                    Height="{Binding IconSize}"
                    MinWidth="{Binding IconSize}"
                    Style="{StaticResource QuickCaptureIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding SearchPlaceholderText}"
                    Visibility="{Binding SearchButtonVisibility}">
                    <FontIcon FontSize="{Binding ActionIconSize}" Glyph="&#xE721;" />
                </Button>
                <TextBox
                    x:Name="SearchTextBox"
                    Grid.Column="0"
                    Height="{Binding IconSize}"
                    MinHeight="26"
                    Padding="8,4,8,0"
                    BorderThickness="1"
                    FontSize="{Binding TextSize}"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"
                    KeyDown="SearchTextBox_KeyDown"
                    PlaceholderText="{Binding SearchPlaceholderText}"
                    Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Visibility="{Binding SearchBoxVisibility}" />
                <Button
                    x:Name="CloseSearchButton"
                    Grid.Column="1"
                    Click="CloseSearchButton_Click"
                    Width="{Binding IconSize}"
                    Height="{Binding IconSize}"
                    MinWidth="{Binding IconSize}"
                    Style="{StaticResource QuickCaptureIconButtonStyle}"
                    Visibility="{Binding SearchBoxVisibility}">
                    <FontIcon FontSize="{Binding ActionIconSize}" Glyph="&#xE711;" />
                </Button>
            </Grid>

            <TextBlock
                Grid.Row="2"
                Margin="2,-2,6,0"
                FontSize="{Binding SecondaryTextSize}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{Binding SearchScopeText}"
                TextAlignment="Center"
                TextTrimming="CharacterEllipsis"
                Visibility="{Binding SearchScopeVisibility}" />

            <TextBlock
                Grid.Row="2"
                Margin="2,-2,6,0"
                FontSize="{Binding SecondaryTextSize}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{Binding RecentCaptureStatusText}"
                TextAlignment="Center"
                TextTrimming="CharacterEllipsis"
                Visibility="{Binding RecentCaptureStatusVisibility}" />

            <Grid Grid.Row="3">
                <StackPanel
                    x:Name="EmptyState"
                    MaxWidth="220"
                    HorizontalAlignment="Center"
                    Spacing="6"
                    VerticalAlignment="Center"
                    Visibility="{Binding EmptyStateVisibility}">
                    <FontIcon
                        x:Name="EmptyStateIcon"
                        FontSize="{Binding EmptyIconSize}"
                        Glyph="&#xE8A5;"
                        HorizontalAlignment="Center" />
                    <TextBlock
                        FontSize="{Binding TitleTextSize}"
                        Text="{Binding EmptyStateTitle}"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                    <TextBlock
                        FontSize="{Binding TextSize}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        MaxLines="2"
                        Text="{Binding EmptyStateText}"
                        TextAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="Wrap" />
                    <Button
                        Click="EnableRecentCaptureButton_Click"
                        FontSize="{Binding SegmentTextSize}"
                        HorizontalAlignment="Center"
                        Style="{StaticResource QuickCaptureSegmentButtonStyle}"
                        Content="{Binding EnableRecentCaptureText}"
                        Visibility="{Binding RecentCaptureActionVisibility}" />
                </StackPanel>

                <ListView
                    x:Name="ItemsListView"
                    Background="Transparent"
                    DoubleTapped="ItemsListView_DoubleTapped"
                    HorizontalContentAlignment="Stretch"
                    ItemsSource="{Binding Items}"
                    KeyDown="ItemsListView_KeyDown"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.HorizontalScrollMode="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    SelectionMode="Single"
                    SelectionChanged="ItemsListView_SelectionChanged"
                    Visibility="{Binding ListVisibility}">
                    <ListView.ItemContainerTransitions>
                        <TransitionCollection />
                    </ListView.ItemContainerTransitions>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,4" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="UseSystemFocusVisuals" Value="False" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <ContentPresenter
                                            Content="{TemplateBinding Content}"
                                            ContentTemplate="{TemplateBinding ContentTemplate}"
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid
                                x:Name="QuickCaptureItemRoot"
                                HorizontalAlignment="Stretch"
                                Padding="8,5,4,5"
                                Background="Transparent"
                                CanDrag="True"
                                DataContextChanged="QuickCaptureItem_DataContextChanged"
                                DragStarting="QuickCaptureItem_DragStarting"
                                PointerEntered="QuickCaptureItem_PointerEntered"
                                PointerExited="QuickCaptureItem_PointerExited"
                                RightTapped="QuickCaptureItem_RightTapped"
                                Tapped="QuickCaptureItem_Tapped">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    x:Name="ItemHoverBackground"
                                    Grid.ColumnSpan="2"
                                    Margin="-4,-3,-2,-3"
                                    Background="Transparent"
                                    CornerRadius="7"
                                    Opacity="0" />
                                <FontIcon
                                    Grid.Column="0"
                                    Margin="0,2,8,0"
                                    FontSize="{Binding TypeIconSize}"
                                    Glyph="{Binding TypeGlyph}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <StackPanel
                                    x:Name="ItemContentHost"
                                    Grid.Column="1"
                                    Margin="0,0,28,0"
                                    MinWidth="0"
                                    Spacing="4">
                                    <Border
                                        x:Name="ImagePreviewBorder"
                                        Width="116"
                                        Height="72"
                                        HorizontalAlignment="Left"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        CornerRadius="6"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        Padding="2"
                                        Visibility="{Binding ImagePreviewVisibility}">
                                        <Image Stretch="Uniform">
                                            <Image.Source>
                                                <BitmapImage DecodePixelWidth="180" UriSource="{Binding ImagePreviewUri}" />
                                            </Image.Source>
                                        </Image>
                                    </Border>
                                    <TextBlock
                                        x:Name="ItemTextBlock"
                                        FontSize="{Binding TextSize}"
                                        MaxLines="2"
                                        Text="{Binding DisplayText}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="Wrap"
                                        Visibility="{Binding TextPreviewVisibility}" />
                                    <TextBlock
                                        FontSize="{Binding SecondaryTextSize}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding UpdatedAtText}" />
                                </StackPanel>
                                <Grid
                                    x:Name="ItemActionHost"
                                    Grid.ColumnSpan="2"
                                    Canvas.ZIndex="2"
                                    Margin="0,0,6,0"
                                    HorizontalAlignment="Right"
                                    IsHitTestVisible="False"
                                    Opacity="0"
                                    VerticalAlignment="Center">
                                    <StackPanel
                                        x:Name="ItemActionButtons"
                                        Padding="3"
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal"
                                        Spacing="4"
                                        VerticalAlignment="Center">
                                        <Button
                                            x:Name="MovePinnedItemUpButton"
                                            Click="MovePinnedItemUpButton_Click"
                                            IsEnabled="{Binding CanMovePinnedUp}"
                                            AutomationProperties.Name="{Binding MoveUpTooltip}"
                                            Style="{StaticResource QuickCaptureItemActionButtonStyle}"
                                            Tag="{Binding}"
                                            ToolTipService.ToolTip="{Binding MoveUpTooltip}"
                                            Visibility="{Binding PinnedSortControlsVisibility}">
                                            <FontIcon FontSize="11" Glyph="&#xE70E;" />
                                        </Button>
                                        <Button
                                            x:Name="MovePinnedItemDownButton"
                                            Click="MovePinnedItemDownButton_Click"
                                            IsEnabled="{Binding CanMovePinnedDown}"
                                            AutomationProperties.Name="{Binding MoveDownTooltip}"
                                            Style="{StaticResource QuickCaptureItemActionButtonStyle}"
                                            Tag="{Binding}"
                                            ToolTipService.ToolTip="{Binding MoveDownTooltip}"
                                            Visibility="{Binding PinnedSortControlsVisibility}">
                                            <FontIcon FontSize="11" Glyph="&#xE70D;" />
                                        </Button>
                                        <Button
                                            x:Name="SaveRecentItemButton"
                                            Click="SaveRecentItemButton_Click"
                                            Style="{StaticResource QuickCaptureItemActionButtonStyle}"
                                            Tag="{Binding}">
                                            <FontIcon FontSize="11" Glyph="&#xE74E;" />
                                        </Button>
                                        <Button
                                            x:Name="PinItemButton"
                                            Click="PinItemButton_Click"
                                            AutomationProperties.Name="{Binding PinTooltip}"
                                            Style="{StaticResource QuickCaptureItemActionButtonStyle}"
                                            Tag="{Binding}"
                                            ToolTipService.ToolTip="{Binding PinTooltip}">
                                            <FontIcon FontSize="11" Glyph="{Binding PinGlyph}" />
                                        </Button>
                                        <Button
                                            x:Name="DeleteItemButton"
                                            Click="DeleteItemButton_Click"
                                            Style="{StaticResource QuickCaptureItemActionButtonStyle}"
                                            Tag="{Binding}">
                                            <FontIcon FontSize="11" Glyph="&#xE74D;" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>

        <Border
            x:Name="StatusToast"
            Grid.Row="1"
            Canvas.ZIndex="10"
            Margin="12,0,12,12"
            Padding="10,6"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Background="{ThemeResource SystemControlAcrylicElementBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="6"
            IsHitTestVisible="False"
            Opacity="0">
            <StackPanel
                Orientation="Horizontal"
                Spacing="10">
                <TextBlock
                    x:Name="StatusToastText"
                    FontSize="{Binding TextSize}"
                    MaxLines="2"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="Wrap"
                    VerticalAlignment="Center" />
                <Button
                    x:Name="StatusToastActionButton"
                    Click="StatusToastActionButton_Click"
                    MinWidth="0"
                    Padding="8,2"
                    Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <Border
            x:Name="EditOverlay"
            Grid.Row="1"
            Canvas.ZIndex="20"
            Margin="10,6,6,8"
            Padding="10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Visibility="Collapsed">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="EditTitleText"
                        Grid.Column="0"
                        FontSize="{Binding TextSize}"
                        FontWeight="SemiBold"
                        TextTrimming="CharacterEllipsis"
                        VerticalAlignment="Center" />
                    <Button
                        x:Name="EditCloseButton"
                        Grid.Column="1"
                        Width="24"
                        Height="24"
                        MinWidth="24"
                        Padding="0"
                        Click="EditCancelButton_Click"
                        Style="{StaticResource QuickCaptureIconButtonStyle}">
                        <FontIcon FontSize="10" Glyph="&#xE711;" />
                    </Button>
                </Grid>

                <TextBox
                    x:Name="EditTextBox"
                    Grid.Row="1"
                    AcceptsReturn="True"
                    BorderThickness="1"
                    FontSize="{Binding TextSize}"
                    KeyDown="EditTextBox_KeyDown"
                    MinHeight="0"
                    Padding="8,6"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    TextWrapping="Wrap"
                    VerticalAlignment="Stretch" />

                <StackPanel
                    Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        x:Name="EditCancelButton"
                        Click="EditCancelButton_Click"
                        FontSize="{Binding SegmentTextSize}"
                        MinWidth="58"
                        Padding="10,3"
                        Style="{StaticResource QuickCaptureSegmentButtonStyle}" />
                    <Button
                        x:Name="EditSaveButton"
                        Click="EditSaveButton_Click"
                        FontSize="{Binding SegmentTextSize}"
                        MinWidth="58"
                        Padding="10,3"
                        Style="{StaticResource QuickCaptureSegmentButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid
            x:Name="ResizeGrid"
            Grid.RowSpan="2"
            IsHitTestVisible="True">
            <Border x:Name="ResizeTop" Height="6" VerticalAlignment="Top" Background="Transparent" Tag="Top" PointerPressed="ResizeBorder_PointerPressed" />
            <Border x:Name="ResizeBottom" Height="6" VerticalAlignment="Bottom" Background="Transparent" Tag="Bottom" PointerPressed="ResizeBorder_PointerPressed" />
            <Border x:Name="ResizeLeft" Width="6" HorizontalAlignment="Left" Background="Transparent" Tag="Left" PointerPressed="ResizeBorder_PointerPressed" />
            <Border x:Name="ResizeRight" Width="6" HorizontalAlignment="Right" Background="Transparent" Tag="Right" PointerPressed="ResizeBorder_PointerPressed" />
            <Border x:Name="ResizeTopLeft" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent" Tag="TopLeft" PointerPressed="ResizeBorder_PointerPressed" />
            <Border x:Name="ResizeTopRight" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" Tag="TopRight" PointerPressed="ResizeBorder_PointerPressed" />
            <Border x:Name="ResizeBottomLeft" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="Transparent" Tag="BottomLeft" PointerPressed="ResizeBorder_PointerPressed" />
            <Border x:Name="ResizeBottomRight" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" Tag="BottomRight" PointerPressed="ResizeBorder_PointerPressed" />
        </Grid>
    </Grid>
</Window>
