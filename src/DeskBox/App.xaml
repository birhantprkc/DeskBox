<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="DeskBox.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="WidgetBackgroundBrush" Color="#F3F3F3" />
                    <SolidColorBrush x:Key="WidgetTextBrush" Color="#1A1A1A" />
                    <SolidColorBrush x:Key="WidgetTextSecondaryBrush" Color="#5A5A5A" />
                    <SolidColorBrush x:Key="WidgetDividerBrush" Color="#D0D0D0" />
                    <SolidColorBrush x:Key="WindowBackgroundBackgroundBrush" Color="Transparent" />
                    <CornerRadius x:Key="OverlayCornerRadius">8</CornerRadius>
                    <CornerRadius x:Key="ComboBoxItemCornerRadius">6</CornerRadius>
                    <CornerRadius x:Key="ComboBoxHiglightBorderCornerRadius">8</CornerRadius>
                    <CornerRadius x:Key="ComboBoxDropDownButtonBackgroundCornerRadius">6</CornerRadius>
                    <Thickness x:Key="ComboBoxDropdownBorderThickness">1</Thickness>
                    <Thickness x:Key="ComboBoxDropdownBorderPadding">0</Thickness>
                    <Thickness x:Key="ComboBoxDropdownContentMargin">4</Thickness>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="WidgetBackgroundBrush" Color="#1F1F1F" />
                    <SolidColorBrush x:Key="WidgetTextBrush" Color="#F5F5F5" />
                    <SolidColorBrush x:Key="WidgetTextSecondaryBrush" Color="#A5A5A5" />
                    <SolidColorBrush x:Key="WidgetDividerBrush" Color="#3C3C3C" />
                    <SolidColorBrush x:Key="WindowBackgroundBackgroundBrush" Color="Transparent" />
                    <CornerRadius x:Key="OverlayCornerRadius">8</CornerRadius>
                    <CornerRadius x:Key="ComboBoxItemCornerRadius">6</CornerRadius>
                    <CornerRadius x:Key="ComboBoxHiglightBorderCornerRadius">8</CornerRadius>
                    <CornerRadius x:Key="ComboBoxDropDownButtonBackgroundCornerRadius">6</CornerRadius>
                    <Thickness x:Key="ComboBoxDropdownBorderThickness">1</Thickness>
                    <Thickness x:Key="ComboBoxDropdownBorderPadding">0</Thickness>
                    <Thickness x:Key="ComboBoxDropdownContentMargin">4</Thickness>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <FontFamily x:Key="DeskBoxMenuFontFamily">Microsoft YaHei UI, Segoe UI Variable, Segoe UI</FontFamily>
            <x:Double x:Key="DeskBoxMenuPresenterVerticalPadding">4</x:Double>
            <x:Double x:Key="DeskBoxMenuItemMinHeight">36</x:Double>
            <x:Double x:Key="DeskBoxMenuItemFontSize">13</x:Double>
            <Thickness x:Key="DeskBoxMenuPresenterPadding">0,4,0,4</Thickness>
            <Thickness x:Key="DeskBoxMenuItemPadding">10,8,10,8</Thickness>

            <Style x:Key="WidgetTitleActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Width" Value="22" />
                <Setter Property="Height" Value="22" />
                <Setter Property="MinWidth" Value="22" />
                <Setter Property="MinHeight" Value="22" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>

            <!-- Shared ToggleSwitch template tuning for settings-style rows. -->
            <x:Double x:Key="ToggleSwitchOuterBorderStrokeThickness">0.25</x:Double>
            <x:Double x:Key="ToggleSwitchThemeMinWidth">72</x:Double>
            <x:Double x:Key="ToggleSwitchPreContentMargin">0</x:Double>
            <x:Double x:Key="ToggleSwitchPostContentMargin">0</x:Double>

            <Style TargetType="ToggleSwitch" BasedOn="{StaticResource DefaultToggleSwitchStyle}">
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Margin" Value="0" />
            </Style>

            <Style x:Key="RoundedToolTipStyle" TargetType="ToolTip" BasedOn="{StaticResource DefaultToolTipStyle}">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToolTip">
                            <ContentPresenter
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="WidgetTooltipCardStyle" TargetType="Border">
                <Setter Property="MaxWidth" Value="360" />
                <Setter Property="Padding" Value="10,7" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Background" Value="{ThemeResource SolidBackgroundFillColorBaseBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource SurfaceStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="WidgetTooltipTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextWrapping" Value="WrapWholeWords" />
            </Style>

            <Style x:Key="WidgetEmptyStatePanelStyle" TargetType="StackPanel">
                <Setter Property="MaxWidth" Value="220" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="WidgetEmptyStateIconStyle" TargetType="FontIcon">
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>

            <Style x:Key="WidgetEmptyStateTitleTextStyle" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="WidgetEmptyStateDescriptionTextStyle" TargetType="TextBlock">
                <Setter Property="MaxWidth" Value="220" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style TargetType="MenuFlyoutPresenter" BasedOn="{StaticResource DefaultMenuFlyoutPresenterStyle}">
                <Setter Property="FontFamily" Value="{StaticResource DeskBoxMenuFontFamily}" />
                <Setter Property="Padding" Value="{StaticResource DeskBoxMenuPresenterPadding}" />
            </Style>

            <Style TargetType="MenuFlyoutItem" BasedOn="{StaticResource DefaultMenuFlyoutItemStyle}">
                <Setter Property="FontFamily" Value="{StaticResource DeskBoxMenuFontFamily}" />
                <Setter Property="MinHeight" Value="{StaticResource DeskBoxMenuItemMinHeight}" />
                <Setter Property="Padding" Value="{StaticResource DeskBoxMenuItemPadding}" />
                <Setter Property="FontSize" Value="{StaticResource DeskBoxMenuItemFontSize}" />
            </Style>

            <Style TargetType="ToggleMenuFlyoutItem" BasedOn="{StaticResource DefaultToggleMenuFlyoutItemStyle}">
                <Setter Property="FontFamily" Value="{StaticResource DeskBoxMenuFontFamily}" />
                <Setter Property="MinHeight" Value="{StaticResource DeskBoxMenuItemMinHeight}" />
                <Setter Property="Padding" Value="{StaticResource DeskBoxMenuItemPadding}" />
                <Setter Property="FontSize" Value="{StaticResource DeskBoxMenuItemFontSize}" />
            </Style>

            <Style TargetType="MenuFlyoutSubItem" BasedOn="{StaticResource DefaultMenuFlyoutSubItemStyle}">
                <Setter Property="FontFamily" Value="{StaticResource DeskBoxMenuFontFamily}" />
                <Setter Property="MinHeight" Value="{StaticResource DeskBoxMenuItemMinHeight}" />
                <Setter Property="Padding" Value="{StaticResource DeskBoxMenuItemPadding}" />
                <Setter Property="FontSize" Value="{StaticResource DeskBoxMenuItemFontSize}" />
            </Style>

            <!-- Custom styles to override missing system styles in some environments -->
            <Style x:Key="SubtleButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
            </Style>

            <!-- Shared widget content surface tokens. -->
            <Style x:Key="WidgetItemActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SubtleButtonStyle}">
                <Setter Property="Width" Value="26" />
                <Setter Property="Height" Value="26" />
                <Setter Property="MinWidth" Value="26" />
                <Setter Property="MinHeight" Value="26" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="6" />
            </Style>

            <Style x:Key="WidgetEditorCommandButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="MinWidth" Value="58" />
                <Setter Property="Padding" Value="10,3" />
                <Setter Property="CornerRadius" Value="6" />
            </Style>

            <Style x:Key="WidgetInlineEditorCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource SubtleButtonStyle}">
                <Setter Property="Width" Value="24" />
                <Setter Property="Height" Value="24" />
                <Setter Property="MinWidth" Value="24" />
                <Setter Property="MinHeight" Value="24" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="5" />
            </Style>

            <Style x:Key="WidgetTextInputStyle" TargetType="TextBox" BasedOn="{StaticResource DefaultTextBoxStyle}">
                <Setter Property="MinHeight" Value="30" />
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style x:Key="WidgetCompactInputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource WidgetTextInputStyle}">
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="TextWrapping" Value="NoWrap" />
            </Style>

            <Style x:Key="WidgetBorderlessInputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource WidgetCompactInputTextBoxStyle}">
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="WidgetSearchTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource WidgetCompactInputTextBoxStyle}">
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="WidgetCompactIconButtonStyle" TargetType="Button" BasedOn="{StaticResource SubtleButtonStyle}">
                <Setter Property="Padding" Value="0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="5" />
            </Style>

            <Style x:Key="WidgetInlineRenameTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource WidgetTextInputStyle}">
                <Setter Property="MinWidth" Value="120" />
                <Setter Property="MinHeight" Value="30" />
                <Setter Property="Padding" Value="8,3" />
                <Setter Property="TextWrapping" Value="NoWrap" />
            </Style>

            <Style x:Key="WidgetTitleRenameTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource WidgetInlineRenameTextBoxStyle}">
                <Setter Property="MinHeight" Value="28" />
                <Setter Property="Padding" Value="8,2" />
            </Style>

            <Style x:Key="WidgetEditorTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource WidgetTextInputStyle}">
                <Setter Property="AcceptsReturn" Value="True" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Top" />
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            </Style>

            <Style x:Key="WidgetInlineEditorOverlayStyle" TargetType="Border">
                <Setter Property="Padding" Value="10" />
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="0.8" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style x:Key="WidgetInlineEditorTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="WidgetConfirmCommandButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="MinWidth" Value="62" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="CornerRadius" Value="6" />
            </Style>

            <Style x:Key="WidgetToastActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Padding" Value="8,2" />
            </Style>

            <Style x:Key="WidgetSegmentedItemStyle" TargetType="toolkit:SegmentedItem">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="{Binding SegmentHeight}" />
                <Setter Property="Height" Value="{Binding SegmentHeight}" />
                <Setter Property="Padding" Value="{Binding SegmentPadding}" />
                <Setter Property="FontSize" Value="{Binding SegmentTextSize}" />
            </Style>

            <Style x:Key="WidgetRowHoverBackgroundStyle" TargetType="Border">
                <Setter Property="Margin" Value="-4,-3,-2,-3" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="CornerRadius" Value="7" />
                <Setter Property="Opacity" Value="0" />
            </Style>

            <Style x:Key="WidgetHoverActionHostStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource SolidBackgroundFillColorBaseBrush}" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="IsHitTestVisible" Value="False" />
                <Setter Property="Opacity" Value="0" />
            </Style>

            <Style x:Key="WidgetCompactToastStyle" TargetType="Border">
                <Setter Property="Padding" Value="10,6" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Bottom" />
                <Setter Property="Background" Value="{ThemeResource SystemControlAcrylicElementBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="IsHitTestVisible" Value="False" />
                <Setter Property="Opacity" Value="0" />
            </Style>

            <Style x:Key="WidgetInlineStatusToastStyle" TargetType="Border" BasedOn="{StaticResource WidgetCompactToastStyle}">
                <Setter Property="MinHeight" Value="30" />
                <Setter Property="MaxWidth" Value="260" />
                <Setter Property="Margin" Value="0,0,8,8" />
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="Background" Value="{ThemeResource SolidBackgroundFillColorBaseBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource SurfaceStrokeColorDefaultBrush}" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Visibility" Value="Collapsed" />
            </Style>

            <Style x:Key="WidgetInlineStatusToastTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="TextWrapping" Value="NoWrap" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>

</Application>
