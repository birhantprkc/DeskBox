<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DeskBox.Controls.WidgetContents.WeatherWidgetContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    SizeChanged="UserControl_SizeChanged">

    <UserControl.Resources>
        <Style x:Key="WeatherIconButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- Detail chip: borderless inline tag (kept for backward compat) -->
        <Style x:Key="WeatherChipStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <!-- Forecast card item -->
        <Style x:Key="WeatherForecastCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Padding="0">

        <!-- ─── Rich Skin Backdrop (condition based gradient) ─── -->
        <Border
            x:Name="RichBackdrop"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            CornerRadius="8"
            IsHitTestVisible="False"
            Visibility="{Binding RichSkinVisibility}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop x:Name="RichBackdropTop" Offset="0" Color="{Binding RichBackdropTopColor}" />
                    <GradientStop x:Name="RichBackdropBottom" Offset="1" Color="{Binding RichBackdropBottomColor}" />
                </LinearGradientBrush>
            </Border.Background>
            <!-- Subtle top highlight for glass depth -->
            <Border
                x:Name="RichGlossOverlay"
                VerticalAlignment="Top"
                Height="60"
                CornerRadius="8,8,0,0"
                IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0" Color="#18FFFFFF" />
                        <GradientStop Offset="1" Color="Transparent" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Border>

        <!-- ─── Rain Animation Layer ─── -->
        <Canvas
            x:Name="RainAnimationCanvas"
            IsHitTestVisible="False"
            Visibility="{Binding RainAnimationVisibility}" />

        <!-- ─── Snow Animation Layer ─── -->
        <Canvas
            x:Name="SnowAnimationCanvas"
            IsHitTestVisible="False"
            Visibility="{Binding SnowAnimationVisibility}" />

        <!-- ─── Thunder Flash Layer ─── -->
        <Border
            x:Name="ThunderFlash"
            IsHitTestVisible="False"
            Visibility="{Binding ThunderAnimationVisibility}"
            CornerRadius="8">
            <Border.Background>
                <SolidColorBrush x:Name="ThunderFlashBrush" Color="Transparent" />
            </Border.Background>
        </Border>

        <!-- ─── Clear Sky Shimmer ─── -->
        <Canvas
            x:Name="ClearShimmerCanvas"
            IsHitTestVisible="False"
            Visibility="{Binding ClearAnimationVisibility}" />

        <!-- ─── Mini Layout (compact, single-column centered) ─── -->
        <Grid
            x:Name="MiniLayout"
            Padding="8,6"
            RowSpacing="2"
            Visibility="{Binding MiniLayoutVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top: Location + refresh -->
            <Grid Grid.Row="0" ColumnSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    FontSize="{Binding CaptionTextSize}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding LocationDisplay}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap"
                    VerticalAlignment="Center"
                    Visibility="{Binding MiniLocationVisibility}" />
                <Button
                    Grid.Column="1"
                    Click="RefreshButton_Click"
                    Style="{StaticResource WeatherIconButtonStyle}"
                    Width="20"
                    Height="20"
                    MinWidth="20"
                    MinHeight="20"
                    ToolTipService.ToolTip="{Binding RefreshTooltip}">
                    <FontIcon FontSize="10" Glyph="&#xE72C;" />
                </Button>
            </Grid>

            <!-- Center: emoji + temperature + description -->
            <StackPanel
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="6">
                <TextBlock
                    FontSize="{Binding CurrentEmojiSize}"
                    Text="{Binding CurrentEmoji}"
                    VerticalAlignment="Center" />
                <TextBlock
                    FontSize="{Binding TemperatureTextSize}"
                    FontWeight="SemiBold"
                    Text="{Binding CurrentTemperatureText}"
                    VerticalAlignment="Center" />
            </StackPanel>

            <TextBlock
                Grid.Row="2"
                HorizontalAlignment="Center"
                FontSize="{Binding CaptionTextSize}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{Binding CurrentDescription}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap"
                Visibility="{Binding MiniDescriptionVisibility}" />

            <StackPanel
                Grid.Row="3"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="6">
                <TextBlock
                    FontSize="9"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{Binding MiniHumidityText}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap"
                    Visibility="{Binding MiniHumidityVisibility}" />
                <TextBlock
                    FontSize="9"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{Binding MiniWindText}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap"
                    Visibility="{Binding MiniWindVisibility}" />
                <TextBlock
                    FontSize="9"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{Binding MiniPrecipText}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap"
                    Visibility="{Binding MiniPrecipVisibility}" />
            </StackPanel>
        </Grid>

        <!-- ─── Compact Layout ─── -->
        <Grid
            x:Name="CompactLayout"
            Padding="10,8"
            RowSpacing="4"
            Visibility="{Binding CompactLayoutVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                    <FontIcon
                        FontSize="10"
                        Glyph="&#xE81D;"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock
                        FontSize="{Binding CaptionTextSize}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding LocationDisplay}"
                        TextWrapping="NoWrap"
                        TextTrimming="CharacterEllipsis"
                        VerticalAlignment="Center" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Click="RefreshButton_Click"
                    Style="{StaticResource WeatherIconButtonStyle}"
                    Width="24"
                    Height="24"
                    MinWidth="24"
                    MinHeight="24"
                    ToolTipService.ToolTip="{Binding RefreshTooltip}">
                    <FontIcon FontSize="11" Glyph="&#xE72C;" />
                </Button>
            </Grid>

            <Grid
                Grid.Row="1"
                ColumnSpacing="8"
                VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    FontSize="{Binding CurrentEmojiSize}"
                    Text="{Binding CurrentEmoji}"
                    VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Spacing="0" VerticalAlignment="Center">
                    <TextBlock
                        FontSize="{Binding TemperatureTextSize}"
                        FontWeight="SemiBold"
                        Text="{Binding CurrentTemperatureText}"
                        TextWrapping="NoWrap" />
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock
                            FontSize="{Binding CaptionTextSize}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding CurrentDescription}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                        <TextBlock
                            FontSize="{Binding CaptionTextSize}"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="{Binding ApparentTemperatureText}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Border
                Grid.Row="2"
                Padding="0,5,0,0"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
                <Grid ColumnSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        HorizontalAlignment="Center"
                        FontSize="{Binding CaptionTextSize}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding HumidityText}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap"
                        Visibility="{Binding HumidityVisibility}" />
                    <TextBlock
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        FontSize="{Binding CaptionTextSize}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding WindText}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap"
                        Visibility="{Binding WindVisibility}" />
                    <TextBlock
                        Grid.Column="2"
                        HorizontalAlignment="Center"
                        FontSize="{Binding CaptionTextSize}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding PrecipitationText}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap"
                        Visibility="{Binding PrecipitationVisibility}" />
                </Grid>
            </Border>
        </Grid>

        <!-- ─── Standard Layout ─── -->
        <Grid
            x:Name="StandardLayout"
            Padding="14,12"
            RowSpacing="6"
            Visibility="{Binding StandardLayoutVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top row: Location + view switch + refresh -->
            <Grid Grid.Row="0" ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="6"
                    VerticalAlignment="Center">
                    <FontIcon
                        FontSize="{Binding CaptionTextSize}"
                        Glyph="&#xE81D;"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        FontSize="{Binding BodyTextSize}"
                        FontWeight="SemiBold"
                        Text="{Binding LocationDisplay}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Click="ViewSwitch_Click"
                    Style="{StaticResource WeatherIconButtonStyle}"
                    Padding="8,2"
                    Width="Auto"
                    ToolTipService.ToolTip="{Binding ViewSwitchTooltip}"
                    Visibility="{Binding ViewSwitchVisibility}">
                    <TextBlock FontSize="{Binding CaptionTextSize}" Text="{Binding ViewSwitchText}" />
                </Button>
                <Button
                    Grid.Column="2"
                    Click="RefreshButton_Click"
                    Style="{StaticResource WeatherIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding RefreshTooltip}">
                    <FontIcon FontSize="12" Glyph="&#xE72C;" />
                </Button>
            </Grid>

            <!-- Hero zone: emoji + temperature + description (left-aligned) -->
            <Grid Grid.Row="1" ColumnSpacing="10" Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    FontSize="{Binding CurrentEmojiSize}"
                    Text="{Binding CurrentEmoji}"
                    VerticalAlignment="Center" />
                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="1">
                    <TextBlock
                        FontSize="{Binding TemperatureTextSize}"
                        FontWeight="Bold"
                        Text="{Binding CurrentTemperatureText}" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock
                            FontSize="{Binding CaptionTextSize}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding CurrentDescription}" />
                        <TextBlock
                            FontSize="{Binding CaptionTextSize}"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="{Binding ApparentTemperatureText}" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Detail items (borderless inline) -->
            <StackPanel
                Grid.Row="2"
                HorizontalAlignment="Left"
                Orientation="Horizontal"
                Spacing="10"
                Margin="0,2,0,4">
                <TextBlock
                    FontSize="{Binding CaptionTextSize}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding HumidityText}"
                    Visibility="{Binding HumidityVisibility}" />
                <TextBlock
                    FontSize="{Binding CaptionTextSize}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding WindText}"
                    Visibility="{Binding WindVisibility}" />
                <TextBlock
                    FontSize="{Binding CaptionTextSize}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding PrecipitationText}"
                    Visibility="{Binding PrecipitationVisibility}" />
                <TextBlock
                    FontSize="{Binding CaptionTextSize}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding UvIndexText}"
                    Visibility="{Binding UvIndexVisibility}" />
            </StackPanel>

            <!-- Today view: hourly horizontal scroll -->
            <ScrollViewer
                x:Name="StandardHourlyScroll"
                Grid.Row="3"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Disabled"
                Visibility="{Binding ForecastVisibility}"
                PointerWheelChanged="HourlyScroll_PointerWheelChanged">
                <ItemsControl
                    HorizontalAlignment="Left"
                    ItemsSource="{Binding HourlyForecast}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Width="46"
                                Height="64"
                                Padding="0,4"
                                Style="{StaticResource WeatherForecastCardStyle}">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="10"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Text="{Binding HourLabel}" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="14"
                                        Text="{Binding Emoji}" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Text="{Binding TemperatureText}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Week forecast (scrollable, fills remaining space) -->
            <ScrollViewer
                x:Name="StandardWeekScroll"
                Grid.Row="3"
                Visibility="{Binding WeekForecastVisibility}"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding DailyForecast}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid
                                Margin="0,2"
                                ColumnSpacing="8"
                                Padding="0,3"
                                ToolTipService.ToolTip="{Binding Description}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding DayLabel}"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    Grid.Column="1"
                                    FontSize="16"
                                    Text="{Binding Emoji}"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    Grid.Column="3"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Text="{Binding TempMaxText}"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    Grid.Column="4"
                                    FontSize="11"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="{Binding TempMinText}"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ─── Detailed Layout ─── -->
        <Grid
            x:Name="DetailedLayout"
            Padding="16,14"
            RowSpacing="8"
            Visibility="{Binding DetailedLayoutVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top row: Location + view switch + refresh -->
            <Grid Grid.Row="0" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="6"
                    VerticalAlignment="Center">
                    <FontIcon
                        FontSize="{Binding BodyTextSize}"
                        Glyph="&#xE81D;"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        FontSize="{Binding TitleTextSize}"
                        FontWeight="SemiBold"
                        Text="{Binding LocationDisplay}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Click="ViewSwitch_Click"
                    Style="{StaticResource WeatherIconButtonStyle}"
                    Padding="8,2"
                    Width="Auto"
                    ToolTipService.ToolTip="{Binding ViewSwitchTooltip}"
                    Visibility="{Binding ViewSwitchVisibility}">
                    <TextBlock FontSize="{Binding CaptionTextSize}" Text="{Binding ViewSwitchText}" />
                </Button>
                <Button
                    Grid.Column="2"
                    Click="RefreshButton_Click"
                    Style="{StaticResource WeatherIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding RefreshTooltip}">
                    <FontIcon FontSize="13" Glyph="&#xE72C;" />
                </Button>
            </Grid>

            <!-- Main temperature display with emoji -->
            <StackPanel
                Grid.Row="1"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="14"
                VerticalAlignment="Center">
                <TextBlock
                    FontSize="{Binding CurrentEmojiSize}"
                    Text="{Binding CurrentEmoji}"
                    VerticalAlignment="Center" />
                <TextBlock
                    FontSize="{Binding TemperatureTextSize}"
                    FontWeight="Bold"
                    Text="{Binding CurrentTemperatureText}"
                    VerticalAlignment="Center" />
            </StackPanel>

            <!-- Description + feels like -->
            <StackPanel
                Grid.Row="2"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="10">
                <TextBlock
                    FontSize="{Binding TitleTextSize}"
                    Text="{Binding CurrentDescription}" />
                <TextBlock
                    FontSize="{Binding BodyTextSize}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding ApparentTemperatureText}" />
            </StackPanel>

            <!-- Detail items (borderless inline) -->
            <StackPanel
                Grid.Row="3"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="10">
                <TextBlock
                    FontSize="{Binding BodyTextSize}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding HumidityText}"
                    Visibility="{Binding HumidityVisibility}" />
                <TextBlock
                    FontSize="{Binding BodyTextSize}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding WindText}"
                    Visibility="{Binding WindVisibility}" />
                <TextBlock
                    FontSize="{Binding BodyTextSize}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding PrecipitationText}"
                    Visibility="{Binding PrecipitationVisibility}" />
                <TextBlock
                    FontSize="{Binding BodyTextSize}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding UvIndexText}"
                    Visibility="{Binding UvIndexVisibility}" />
                <TextBlock
                    FontSize="{Binding BodyTextSize}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding PressureText}"
                    Visibility="{Binding PressureVisibility}" />
            </StackPanel>

            <!-- Sunrise / Sunset -->
            <Grid
                Grid.Row="4"
                ColumnSpacing="16"
                Visibility="{Binding SunriseVisibility}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Grid.Column="0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="6">
                    <TextBlock FontSize="14" Text="&#x2600;&#xFE0F;" />
                    <TextBlock
                        FontSize="{Binding CaptionTextSize}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding SunriseText}" />
                </StackPanel>
                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="6">
                    <TextBlock FontSize="14" Text="&#x1F319;" />
                    <TextBlock
                        FontSize="{Binding CaptionTextSize}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding SunsetText}" />
                </StackPanel>
            </Grid>

            <!-- Today view: hourly horizontal scroll -->
            <ScrollViewer
                x:Name="DetailedHourlyScroll"
                Grid.Row="5"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Disabled"
                Visibility="{Binding ForecastVisibility}"
                PointerWheelChanged="HourlyScroll_PointerWheelChanged">
                <ItemsControl
                    HorizontalAlignment="Left"
                    ItemsSource="{Binding HourlyForecast}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Width="48"
                                Height="86"
                                Padding="0,6"
                                Style="{StaticResource WeatherForecastCardStyle}">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="3">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Text="{Binding HourLabel}" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="18"
                                        Text="{Binding Emoji}" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="{Binding TemperatureText}" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="10"
                                        Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                        Text="{Binding PrecipitationText}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Week forecast (scrollable, fills remaining space) -->
            <ScrollViewer
                x:Name="DetailedWeekScroll"
                Grid.Row="5"
                Visibility="{Binding WeekForecastVisibility}"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding DailyForecast}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid
                                Margin="0,2"
                                ColumnSpacing="10"
                                Padding="0,4"
                                ToolTipService.ToolTip="{Binding Description}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding DayLabel}"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    Grid.Column="1"
                                    FontSize="20"
                                    Text="{Binding Emoji}"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    Grid.Column="3"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Text="{Binding TempMaxText}"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    Grid.Column="4"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="{Binding TempMinText}"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>

        <!-- ─── Refresh Status Toast ─── -->
        <Border
            x:Name="RefreshStatusToast"
            Padding="10,6"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            CornerRadius="6"
            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            Visibility="{Binding RefreshStatusVisibility}">
            <TextBlock
                FontSize="11"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{Binding RefreshStatusText}" />
        </Border>

        <!-- ─── Loading Overlay (first-time fetch + user-triggered refresh) ─── -->
        <Grid
            x:Name="LoadingOverlay"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            CornerRadius="8"
            Visibility="{Binding LoadingVisibility}">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="10">
                <ProgressRing
                    Width="32"
                    Height="32"
                    IsActive="True" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding LoadingText}" />
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
