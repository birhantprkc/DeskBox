<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DeskBox.Controls.WidgetContents.TodoWidgetContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:DeskBox.Controls"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="TodoColorFilterButtonStyle" TargetType="Button" BasedOn="{StaticResource SubtleButtonStyle}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="MinWidth" Value="22" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="11" />
        </Style>

        <Style x:Key="TodoColorFilterSelectedButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="MinWidth" Value="22" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="1.4" />
            <Setter Property="CornerRadius" Value="11" />
        </Style>

        <Style x:Key="TodoCompletionButtonStyle" TargetType="Button" BasedOn="{StaticResource SubtleButtonStyle}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="MinWidth" Value="22" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="TodoItemActionButtonStyle" TargetType="Button" BasedOn="{StaticResource WidgetItemActionButtonStyle}" />

        <Style x:Key="TodoEditorCommandButtonStyle" TargetType="Button" BasedOn="{StaticResource WidgetEditorCommandButtonStyle}" />

        <Style x:Key="TodoConfirmCommandButtonStyle" TargetType="Button" BasedOn="{StaticResource WidgetConfirmCommandButtonStyle}" />

    </UserControl.Resources>

    <Grid
        x:Name="RootGrid"
        Padding="10,8,8,8"
        RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="AddTextBox"
                Grid.Column="0"
                Height="{Binding InputHeight}"
                MinHeight="{Binding InputHeight}"
                Padding="{Binding InputPadding}"
                FontSize="{Binding TextSize}"
                KeyDown="AddTextBox_KeyDown"
                PlaceholderText="{Binding AddPlaceholderText}"
                Style="{StaticResource WidgetBorderlessInputTextBoxStyle}"
                Text="{Binding InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <Button
                x:Name="ExpandInputButton"
                Grid.Column="1"
                Click="ExpandInputButton_Click"
                Width="{Binding InputButtonSize}"
                Height="{Binding InputButtonSize}"
                MinWidth="{Binding InputButtonSize}"
                MinHeight="{Binding InputButtonSize}"
                Style="{StaticResource WidgetCompactIconButtonStyle}"
                ToolTipService.ToolTip="{Binding ExpandInputTooltipText}">
                <FontIcon FontSize="{Binding InputActionIconSize}" Glyph="&#xE740;" />
            </Button>
        </Grid>

        <StackPanel Grid.Row="1" Spacing="6">
            <toolkit:Segmented
                x:Name="TodoFilterSegmented"
                MinHeight="{Binding SegmentHeight}"
                FontSize="{Binding SegmentTextSize}"
                HorizontalAlignment="Stretch"
                SelectionChanged="TodoFilterSegmented_SelectionChanged"
                SelectedIndex="0">
                <toolkit:SegmentedItem
                    Style="{StaticResource WidgetSegmentedItemStyle}"
                    Tag="All"
                    ToolTipService.ToolTip="{Binding AllFilterText}">
                    <TextBlock
                        MinWidth="0"
                        VerticalAlignment="Center"
                        FontSize="{Binding SegmentTextSize}"
                        MaxLines="1"
                        Text="{Binding AllFilterText}"
                        TextAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                </toolkit:SegmentedItem>
                <toolkit:SegmentedItem
                    Style="{StaticResource WidgetSegmentedItemStyle}"
                    Tag="Today"
                    ToolTipService.ToolTip="{Binding TodayFilterText}">
                    <TextBlock
                        MinWidth="0"
                        VerticalAlignment="Center"
                        FontSize="{Binding SegmentTextSize}"
                        MaxLines="1"
                        Text="{Binding TodayFilterText}"
                        TextAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                </toolkit:SegmentedItem>
                <toolkit:SegmentedItem
                    Style="{StaticResource WidgetSegmentedItemStyle}"
                    Tag="Important"
                    ToolTipService.ToolTip="{Binding ImportantFilterText}">
                    <TextBlock
                        MinWidth="0"
                        VerticalAlignment="Center"
                        FontSize="{Binding SegmentTextSize}"
                        MaxLines="1"
                        Text="{Binding ImportantFilterText}"
                        TextAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                </toolkit:SegmentedItem>
                <toolkit:SegmentedItem
                    Style="{StaticResource WidgetSegmentedItemStyle}"
                    Tag="Completed"
                    ToolTipService.ToolTip="{Binding CompletedFilterText}">
                    <TextBlock
                        MinWidth="0"
                        VerticalAlignment="Center"
                        FontSize="{Binding SegmentTextSize}"
                        MaxLines="1"
                        Text="{Binding CompletedFilterText}"
                        TextAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                </toolkit:SegmentedItem>
            </toolkit:Segmented>

            <StackPanel
                Orientation="Horizontal"
                Spacing="6"
                Visibility="{Binding ColorFilterVisibility}">
                <Button
                    x:Name="RedColorFilterButton"
                    Click="RedColorFilterButton_Click"
                    Style="{StaticResource TodoColorFilterButtonStyle}"
                    Visibility="{Binding RedColorFilterVisibility}">
                    <Ellipse Width="9" Height="9" Fill="#E34D4D" />
                </Button>
                <Button
                    x:Name="OrangeColorFilterButton"
                    Click="OrangeColorFilterButton_Click"
                    Style="{StaticResource TodoColorFilterButtonStyle}"
                    Visibility="{Binding OrangeColorFilterVisibility}">
                    <Ellipse Width="9" Height="9" Fill="#F08A3C" />
                </Button>
                <Button
                    x:Name="YellowColorFilterButton"
                    Click="YellowColorFilterButton_Click"
                    Style="{StaticResource TodoColorFilterButtonStyle}"
                    Visibility="{Binding YellowColorFilterVisibility}">
                    <Ellipse Width="9" Height="9" Fill="#F2C94C" />
                </Button>
                <Button
                    x:Name="GreenColorFilterButton"
                    Click="GreenColorFilterButton_Click"
                    Style="{StaticResource TodoColorFilterButtonStyle}"
                    Visibility="{Binding GreenColorFilterVisibility}">
                    <Ellipse Width="9" Height="9" Fill="#4CAF6D" />
                </Button>
                <Button
                    x:Name="BlueColorFilterButton"
                    Click="BlueColorFilterButton_Click"
                    Style="{StaticResource TodoColorFilterButtonStyle}"
                    Visibility="{Binding BlueColorFilterVisibility}">
                    <Ellipse Width="9" Height="9" Fill="#4D8FE3" />
                </Button>
                <Button
                    x:Name="PurpleColorFilterButton"
                    Click="PurpleColorFilterButton_Click"
                    Style="{StaticResource TodoColorFilterButtonStyle}"
                    Visibility="{Binding PurpleColorFilterVisibility}">
                    <Ellipse Width="9" Height="9" Fill="#9B6BE8" />
                </Button>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ListView
                x:Name="TodoListView"
                Grid.Row="0"
                IsItemClickEnabled="False"
                CanDragItems="True"
                CanReorderItems="True"
                AllowDrop="True"
                DragItemsStarting="TodoListView_DragItemsStarting"
                DragItemsCompleted="TodoListView_DragItemsCompleted"
                ItemsSource="{Binding VisibleItems}"
                SelectionMode="None"
                Visibility="{Binding ListVisibility}">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,4" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid
                            MinHeight="28"
                            Padding="6,3"
                            Background="Transparent"
                            ColumnSpacing="4"
                            DataContextChanged="TodoItem_DataContextChanged"
                            PointerEntered="TodoItem_PointerEntered"
                            PointerExited="TodoItem_PointerExited"
                            RightTapped="TodoItem_RightTapped">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                x:Name="TodoItemHoverBackground"
                                Grid.ColumnSpan="3"
                                Style="{StaticResource WidgetRowHoverBackgroundStyle}" />

                            <Button
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Click="ItemCompletionButton_Click"
                                Style="{StaticResource TodoCompletionButtonStyle}">
                                <Grid Width="14" Height="14">
                                    <Border
                                        x:Name="TodoCompletionBox"
                                        BorderBrush="{ThemeResource TextFillColorSecondaryBrush}"
                                        BorderThickness="1"
                                        CornerRadius="3" />
                                    <FontIcon
                                        FontSize="10"
                                        Glyph="{Binding CompletionGlyph}"
                                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                        Opacity="{Binding CompletionGlyphOpacity}" />
                                </Grid>
                            </Button>

                            <Ellipse
                                Grid.Column="1"
                                Width="6"
                                Height="6"
                                Margin="-2,0,0,0"
                                VerticalAlignment="Center"
                                Fill="{Binding ColorMarkerBrush}"
                                Visibility="{Binding ColorMarkerVisibility}" />

                            <Grid
                                Grid.Column="2"
                                MinHeight="20"
                                VerticalAlignment="Center"
                                RowSpacing="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Top"
                                    DoubleTapped="TodoItemText_DoubleTapped"
                                    FontSize="{Binding ElementName=TodoListView, Path=DataContext.TextSize}"
                                    CharacterSpacing="8"
                                    LineHeight="{Binding ElementName=TodoListView, Path=DataContext.ItemTextLineHeight}"
                                    LineStackingStrategy="BlockLineHeight"
                                    MaxLines="10"
                                    Text="{Binding Text, Mode=OneWay}"
                                    TextAlignment="Left"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="Wrap"
                                    Visibility="{Binding TextVisibility}" />

                                <TextBlock
                                    Grid.Row="1"
                                    Margin="0,1,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="{Binding ElementName=TodoListView, Path=DataContext.SecondaryTextSize}"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="{Binding DueStatusText}"
                                    TextTrimming="CharacterEllipsis"
                                    Visibility="{Binding DueStatusVisibility}" />
                            </Grid>

                            <Border
                                x:Name="TodoItemActionHost"
                                Grid.Column="2"
                                Canvas.ZIndex="2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Style="{StaticResource WidgetHoverActionHostStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="2">
                                    <Button
                                        Click="ImportantItemButton_Click"
                                        Style="{StaticResource TodoItemActionButtonStyle}">
                                        <FontIcon FontSize="12" Glyph="{Binding ImportantGlyph}" />
                                    </Button>

                                    <Button
                                        x:Name="DeleteItemButton"
                                        Click="DeleteItemButton_Click"
                                        Style="{StaticResource TodoItemActionButtonStyle}">
                                        <FontIcon FontSize="12" Glyph="&#xE74D;" />
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel
                Grid.Row="0"
                Spacing="4"
                Style="{StaticResource WidgetEmptyStatePanelStyle}"
                Visibility="{Binding EmptyStateVisibility}">
                <TextBlock
                    FontSize="{Binding TitleTextSize}"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource WidgetEmptyStateTitleTextStyle}"
                    Text="{Binding EmptyStateTitle}" />
                <TextBlock
                    FontSize="{Binding SecondaryTextSize}"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Style="{StaticResource WidgetEmptyStateDescriptionTextStyle}"
                    Text="{Binding EmptyStateText}" />
            </StackPanel>

        </Grid>

        <Grid
            Grid.Row="3"
            ColumnSpacing="8"
            Visibility="{Binding FooterVisibility}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="{Binding SecondaryTextSize}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{Binding ItemsLeftText}"
                TextTrimming="CharacterEllipsis"
                Visibility="{Binding FooterStatsVisibility}" />

            <Button
                x:Name="ClearCompletedButton"
                Grid.Column="1"
                MinWidth="0"
                Padding="8,4"
                Click="ClearCompletedButton_Click"
                IsEnabled="{Binding HasCompletedItems}"
                Visibility="{Binding ClearCompletedButtonVisibility}">
                <TextBlock FontSize="{Binding SecondaryTextSize}" Text="{Binding ClearCompletedText}" />
            </Button>
        </Grid>

        <Border
            x:Name="UndoToast"
            Grid.RowSpan="4"
            Canvas.ZIndex="10"
            Margin="10,0,10,10"
            Style="{StaticResource WidgetCompactToastStyle}">
            <StackPanel
                Orientation="Horizontal"
                Spacing="10">
                <TextBlock
                    x:Name="UndoToastText"
                    FontSize="{Binding TextSize}"
                    MaxLines="2"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="Wrap"
                    VerticalAlignment="Center" />
                <Button
                    x:Name="UndoToastActionButton"
                    Click="UndoButton_Click"
                    Style="{StaticResource WidgetToastActionButtonStyle}"
                    Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <controls:WidgetInlineEditor
            x:Name="TodoInlineEditor"
            Grid.RowSpan="4"
            Canvas.ZIndex="20"
            CancelRequested="TodoEditCancelButton_Click"
            CommandFontSize="{Binding FilterTextSize}"
            EditorFontSize="{Binding TextSize}"
            EditorKeyDown="TodoEditTextBox_KeyDown"
            SaveRequested="TodoEditSaveButton_Click"
            TitleFontSize="{Binding TextSize}"
            Visibility="Collapsed" />

    </Grid>
</UserControl>
