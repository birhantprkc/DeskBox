<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DeskBox.Controls.WidgetContents.MusicWidgetContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="MusicIconButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="15" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid
                            x:Name="IconButtonRoot"
                            Background="Transparent"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <VisualState.Setters>
                                            <Setter Target="IconButtonHoverSurface.Opacity" Value="0" />
                                            <Setter Target="IconButtonPressedSurface.Opacity" Value="0" />
                                            <Setter Target="IconButtonContentPresenter.Opacity" Value="0.92" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="IconButtonHoverSurface.Opacity" Value="0.16" />
                                            <Setter Target="IconButtonPressedSurface.Opacity" Value="0" />
                                            <Setter Target="IconButtonContentPresenter.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="IconButtonHoverSurface.Opacity" Value="0.10" />
                                            <Setter Target="IconButtonPressedSurface.Opacity" Value="0.24" />
                                            <Setter Target="IconButtonContentPresenter.Opacity" Value="0.82" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="IconButtonHoverSurface.Opacity" Value="0" />
                                            <Setter Target="IconButtonPressedSurface.Opacity" Value="0" />
                                            <Setter Target="IconButtonContentPresenter.Opacity" Value="0.34" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border
                                x:Name="IconButtonHoverSurface"
                                Background="#FFFFFFFF"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                IsHitTestVisible="False"
                                Opacity="0" />
                            <Border
                                x:Name="IconButtonPressedSurface"
                                Background="#FFFFFFFF"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                IsHitTestVisible="False"
                                Opacity="0" />
                            <ContentPresenter
                                x:Name="IconButtonContentPresenter"
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MusicPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{ThemeResource SystemControlHighlightAccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="21" />
            <Setter Property="Foreground" Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid
                            x:Name="PrimaryButtonRoot"
                            Background="Transparent"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <VisualState.Setters>
                                            <Setter Target="PrimarySurface.Opacity" Value="1" />
                                            <Setter Target="PrimaryHoverOverlay.Opacity" Value="0" />
                                            <Setter Target="PrimaryPressedOverlay.Opacity" Value="0" />
                                            <Setter Target="PrimaryContentPresenter.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="PrimarySurface.Opacity" Value="1" />
                                            <Setter Target="PrimaryHoverOverlay.Opacity" Value="0.10" />
                                            <Setter Target="PrimaryPressedOverlay.Opacity" Value="0" />
                                            <Setter Target="PrimaryContentPresenter.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="PrimarySurface.Opacity" Value="0.96" />
                                            <Setter Target="PrimaryHoverOverlay.Opacity" Value="0" />
                                            <Setter Target="PrimaryPressedOverlay.Opacity" Value="0.16" />
                                            <Setter Target="PrimaryContentPresenter.Opacity" Value="0.86" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="PrimarySurface.Opacity" Value="0.42" />
                                            <Setter Target="PrimaryHoverOverlay.Opacity" Value="0" />
                                            <Setter Target="PrimaryPressedOverlay.Opacity" Value="0" />
                                            <Setter Target="PrimaryContentPresenter.Opacity" Value="0.40" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border
                                x:Name="PrimarySurface"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                IsHitTestVisible="False" />
                            <Border
                                x:Name="PrimaryHoverOverlay"
                                Background="#FFFFFFFF"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                IsHitTestVisible="False"
                                Opacity="0" />
                            <Border
                                x:Name="PrimaryPressedOverlay"
                                Background="#66000000"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                IsHitTestVisible="False"
                                Opacity="0" />
                            <ContentPresenter
                                x:Name="PrimaryContentPresenter"
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid
        x:Name="RootGrid"
        Padding="0"
        PointerPressed="RootGrid_PointerPressed">
        <Border
            x:Name="ArtworkBackdrop"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            CornerRadius="{Binding ArtworkBackdropCornerRadius}"
            IsHitTestVisible="False"
            Visibility="{Binding ArtworkBackdropVisibility}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="{Binding ArtworkBackdropStartColor}" />
                    <GradientStop Offset="0.48" Color="{Binding ArtworkBackdropMidColor}" />
                    <GradientStop Offset="1" Color="{Binding ArtworkBackdropEndColor}" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Grid
            x:Name="RhythmBackdrop"
            Margin="0"
            Height="48"
            VerticalAlignment="Bottom"
            IsHitTestVisible="False"
            Opacity="{Binding RhythmBarsOpacity}"
            Visibility="{Binding RhythmBarsVisibility}">
            <ItemsControl
                Margin="12,0,12,7"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Bottom"
                ItemsSource="{Binding VisualizerBars}"
                Visibility="{Binding SoftWaveVisibility}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="2"
                            VerticalAlignment="Bottom" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Width="4"
                            Height="{Binding Height}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            CornerRadius="2"
                            Opacity="{Binding Opacity}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0" Color="{Binding AccentColor}" />
                                    <GradientStop Offset="1" Color="{Binding GlassEndColor}" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl
                Margin="12,0,12,7"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Bottom"
                ItemsSource="{Binding VisualizerBars}"
                Visibility="{Binding GlassSpectrumVisibility}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="2"
                            VerticalAlignment="Bottom" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Width="3"
                            Height="{Binding Height}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            BorderThickness="1"
                            CornerRadius="2.5"
                            Opacity="{Binding Opacity}">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{Binding GlassStrokeColor}" />
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0" Color="{Binding GlassStartColor}" />
                                    <GradientStop Offset="0.42" Color="{Binding GlassMidColor}" />
                                    <GradientStop Offset="1" Color="{Binding GlassEndColor}" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl
                Margin="12,0,12,9"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Bottom"
                ItemsSource="{Binding VisualizerBars}"
                Visibility="{Binding DotPulseVisibility}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="2"
                            VerticalAlignment="Bottom" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Ellipse
                            Width="{Binding DotSize}"
                            Height="{Binding DotSize}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Opacity="{Binding Opacity}"
                            Stroke="{Binding GlassStrokeColor}"
                            StrokeThickness="0.5">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="{Binding AccentColor}" />
                            </Ellipse.Fill>
                        </Ellipse>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl
                Margin="12,0,12,5"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Bottom"
                ItemsSource="{Binding VisualizerBars}"
                Visibility="{Binding LineSpectrumVisibility}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="2"
                            VerticalAlignment="Bottom" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Width="2"
                            Height="{Binding Height}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            CornerRadius="1"
                            Opacity="{Binding Opacity}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0" Color="{Binding AccentColor}" />
                                    <GradientStop Offset="1" Color="{Binding GlassMidColor}" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl
                Margin="12,0,12,5"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Bottom"
                ItemsSource="{Binding VisualizerBars}"
                Visibility="{Binding StackedEqualizerVisibility}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="2"
                            VerticalAlignment="Bottom" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid
                            Width="5"
                            Height="43"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom">
                            <ItemsControl
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                ItemsSource="{Binding EqualizerSegments}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel
                                            Orientation="Vertical"
                                            Spacing="1.2"
                                            VerticalAlignment="Bottom" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Width="5"
                                            Height="3"
                                            CornerRadius="1"
                                            Opacity="{Binding Opacity}">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding Color}" />
                                            </Border.Background>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <Grid
            x:Name="ContentGrid"
            Padding="12,12,12,11"
            ColumnSpacing="12"
            RowSpacing="8"
            VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="AlbumColumn" Width="82" />
                <ColumnDefinition Width="*" MinWidth="0" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="TopRow" Height="82" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                x:Name="AlbumArtShadow"
                Grid.Row="0"
                Grid.Column="0"
                Width="82"
                Height="82"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="#66000000"
                CornerRadius="12"
                Opacity="0.28"
                Translation="0,4,0" />

            <Border
                x:Name="AlbumArtSurface"
                Grid.Row="0"
                Grid.Column="0"
                Width="82"
                Height="82"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                PointerEntered="AlbumArtSurface_PointerEntered"
                PointerExited="AlbumArtSurface_PointerExited"
                PointerMoved="AlbumArtSurface_PointerMoved"
                SizeChanged="AlbumArtSurface_SizeChanged">
                <Grid>
                    <Image
                        Source="{Binding ThumbnailImage}"
                        Stretch="UniformToFill"
                        Visibility="{Binding ThumbnailVisibility}" />
                    <Border
                        IsHitTestVisible="False"
                        Opacity="0.34">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#66FFFFFF" />
                                <GradientStop Offset="0.42" Color="#12FFFFFF" />
                                <GradientStop Offset="1" Color="#33000000" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border
                        Margin="1"
                        BorderBrush="#24FFFFFF"
                        BorderThickness="1"
                        CornerRadius="11"
                        IsHitTestVisible="False" />
                    <Grid Visibility="{Binding ThumbnailPlaceholderVisibility}">
                        <Rectangle Fill="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                        <FontIcon
                            FontSize="30"
                            Glyph="&#xEC4F;"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                </Grid>
            </Border>

            <Grid
                x:Name="TrackInfoGrid"
                Grid.Row="0"
                Grid.Column="1"
                MinWidth="0"
                RowSpacing="4"
                VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid
                    x:Name="TitleMarqueeHost"
                    Grid.Row="0"
                    MinWidth="0"
                    SizeChanged="TitleMarqueeHost_SizeChanged">
                    <Grid.Clip>
                        <RectangleGeometry x:Name="TitleMarqueeClip" />
                    </Grid.Clip>
                    <TextBlock
                        x:Name="TitleStaticText"
                        FontSize="{Binding TitleTextSize}"
                        FontWeight="SemiBold"
                        MaxLines="1"
                        MinWidth="0"
                        Text="{Binding Title}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                    <Canvas
                        x:Name="TitleMarqueeCanvas"
                        Height="{Binding ActualHeight, ElementName=TitleStaticText}"
                        IsHitTestVisible="False"
                        Visibility="Collapsed">
                        <TextBlock
                            x:Name="TitleTextPrimary"
                            FontSize="{Binding TitleTextSize}"
                            FontWeight="SemiBold"
                            MaxLines="1"
                            Text="{Binding Title}"
                            TextTrimming="Clip"
                            TextWrapping="NoWrap" />
                        <TextBlock
                            x:Name="TitleTextClone"
                            FontSize="{Binding TitleTextSize}"
                            FontWeight="SemiBold"
                            MaxLines="1"
                            Text="{Binding Title}"
                            TextTrimming="Clip"
                            TextWrapping="NoWrap" />
                    </Canvas>
                    <Canvas
                        Width="0"
                        Height="0"
                        IsHitTestVisible="False"
                        Opacity="0">
                        <TextBlock
                            x:Name="TitleMeasureText"
                            FontSize="{Binding TitleTextSize}"
                            FontWeight="SemiBold"
                            MaxLines="1"
                            Text="{Binding Title}"
                            TextTrimming="Clip"
                            TextWrapping="NoWrap" />
                    </Canvas>
                </Grid>

                <TextBlock
                    Grid.Row="1"
                    FontSize="{Binding SecondaryTextSize}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    MaxLines="1"
                    MinWidth="0"
                    Text="{Binding Artist}"
                    TextTrimming="CharacterEllipsis" />

                <TextBlock
                    Grid.Row="2"
                    FontSize="{Binding CaptionTextSize}"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    MaxLines="1"
                    MinWidth="0"
                    Text="{Binding StatusText}"
                    TextTrimming="CharacterEllipsis" />
            </Grid>

            <Grid
                x:Name="ProgressRow"
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,3,0,0"
                ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="PositionColumn" Width="34" />
                    <ColumnDefinition Width="*" MinWidth="0" />
                    <ColumnDefinition x:Name="DurationColumn" Width="34" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="{Binding CaptionTextSize}"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{Binding PositionText}"
                    TextAlignment="Left" />

                <Grid
                    x:Name="ProgressHost"
                    Grid.Column="1"
                    Height="24"
                    MinWidth="44"
                    Background="Transparent"
                    HorizontalAlignment="Stretch"
                    PointerEntered="ProgressHost_PointerEntered"
                    PointerExited="ProgressHost_PointerExited"
                    PointerMoved="ProgressHost_PointerMoved"
                    PointerPressed="ProgressHost_PointerPressed"
                    PointerReleased="ProgressHost_PointerReleased">
                    <Border
                        x:Name="ProgressTrack"
                        Height="4"
                        VerticalAlignment="Center"
                        Background="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
                        CornerRadius="2"
                        Opacity="0.36" />
                    <Border
                        x:Name="ProgressFill"
                        Height="4"
                        Width="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{Binding MusicAccentBrush}"
                        CornerRadius="2" />
                    <Ellipse
                        x:Name="ProgressThumb"
                        Width="10"
                        Height="10"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Fill="{Binding MusicAccentBrush}"
                        Opacity="0"
                        Translation="-5,0,0" />
                </Grid>

                <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    FontSize="{Binding CaptionTextSize}"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{Binding DurationText}"
                    TextAlignment="Right" />
            </Grid>

            <StackPanel
                x:Name="ControlsPanel"
                Grid.Row="2"
                Grid.ColumnSpan="2"
                Margin="0,5,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="12"
                VerticalAlignment="Bottom">
                <Button
                    x:Name="PlaybackModeButton"
                    Click="PlaybackModeButton_Click"
                    IsEnabled="{Binding CanChangePlaybackMode}"
                    Opacity="{Binding PlaybackModeOpacity}"
                    Style="{StaticResource MusicIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding PlaybackModeTooltip}">
                    <FontIcon FontSize="14" Glyph="{Binding PlaybackModeGlyph}" />
                </Button>

                <Button
                    x:Name="PreviousButton"
                    Click="PreviousButton_Click"
                    IsEnabled="{Binding CanGoPrevious}"
                    Style="{StaticResource MusicIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding PreviousTooltip}">
                    <FontIcon FontSize="15" Glyph="&#xE100;" />
                </Button>

                <Button
                    x:Name="PlayPauseButton"
                    Background="{Binding PlayPauseButtonBackgroundBrush}"
                    Click="PlayPauseButton_Click"
                    IsEnabled="{Binding CanPlayPause}"
                    Style="{StaticResource MusicPrimaryButtonStyle}"
                    ToolTipService.ToolTip="{Binding PlayPauseTooltip}">
                    <Grid Width="20" Height="20">
                        <Viewbox
                            Width="17"
                            Height="17"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Translation="1,0,0"
                            Visibility="{Binding PlayIconVisibility}">
                            <Path
                                Data="M 7.2,3.8 C 7.2,2.9 8.2,2.4 9.0,2.9 L 18.1,8.6 C 19.2,9.3 19.2,10.9 18.1,11.6 L 9.0,17.3 C 8.2,17.8 7.2,17.3 7.2,16.4 Z"
                                Fill="#FFFFFFFF"
                                Stretch="Uniform" />
                        </Viewbox>
                        <Grid
                            Width="16"
                            Height="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding PauseIconVisibility}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="4" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Grid.Column="0"
                                Width="5"
                                Height="16"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="#FFFFFFFF"
                                CornerRadius="2.5" />
                            <Border
                                Grid.Column="2"
                                Width="5"
                                Height="16"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Background="#FFFFFFFF"
                                CornerRadius="2.5" />
                        </Grid>
                    </Grid>
                </Button>

                <Button
                    x:Name="NextButton"
                    Click="NextButton_Click"
                    IsEnabled="{Binding CanGoNext}"
                    Style="{StaticResource MusicIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding NextTooltip}">
                    <FontIcon FontSize="15" Glyph="&#xE101;" />
                </Button>

                <Button
                    x:Name="VolumeButton"
                    Click="VolumeButton_Click"
                    Style="{StaticResource MusicIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding VolumeTooltip}">
                    <FontIcon FontSize="15" Glyph="&#xE767;" />
                </Button>
            </StackPanel>
        </Grid>

        <Border
            x:Name="InlineVolumePanel"
            Width="238"
            Height="48"
            Padding="10,8"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            PointerPressed="InlineVolumePanel_PointerPressed"
            Visibility="Collapsed">
            <Grid ColumnSpacing="9">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{Binding VolumeTextSize}"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    Text="{Binding SystemVolumeText}"
                    TextAlignment="Center" />

                <Slider
                    x:Name="InlineSystemVolumeSlider"
                    Grid.Column="1"
                    Height="28"
                    Margin="0,-4,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    IsThumbToolTipEnabled="False"
                    LargeChange="0.1"
                    Maximum="1"
                    Minimum="0"
                    Orientation="Horizontal"
                    SmallChange="0.01"
                    StepFrequency="0.01"
                    Value="{Binding SystemVolume, Mode=TwoWay}"
                    ValueChanged="InlineSystemVolumeSlider_ValueChanged" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
