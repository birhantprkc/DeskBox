<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DeskBox.Controls.WidgetShell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:DeskBox.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        x:Name="ShellRoot"
        AllowDrop="True"
        Background="Transparent"
        PointerEntered="ShellRoot_PointerEntered"
        PointerExited="ShellRoot_PointerExited">
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            x:Name="BackgroundPlate"
            Grid.RowSpan="2"
            BorderThickness="0"
            CornerRadius="0" />

        <Grid
            x:Name="TitleBarGrid"
            Grid.Row="0"
            Padding="14,7,12,5"
            HorizontalAlignment="Stretch"
            Background="Transparent"
            PointerMoved="TitleBarGrid_PointerMoved"
            PointerPressed="TitleBarGrid_PointerPressed"
            PointerReleased="TitleBarGrid_PointerReleased"
            PointerCaptureLost="TitleBarGrid_PointerCaptureLost"
            RightTapped="TitleBarGrid_RightTapped">
            <ContentPresenter
                x:Name="CustomTitleBarContentPresenter"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Content="{x:Bind TitleBarContent, Mode=OneWay}" />

            <Grid x:Name="DefaultTitleBarContentHost">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    x:Name="TitleIdentityHost"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    IsDoubleTapEnabled="{x:Bind IsTitleEditable, Mode=OneWay}"
                    Orientation="Horizontal"
                    Spacing="8"
                    DoubleTapped="TitleText_DoubleTapped">
                    <controls:WidgetTitleIcon
                        x:Name="TitleIcon"
                        AccentColor="{x:Bind TitleIconAccentColor, Mode=OneWay}"
                        Glyph="{x:Bind TitleGlyph, Mode=OneWay}"
                        IconSize="{Binding TitleIconSize}"
                        IconKind="{x:Bind TitleIconKind, Mode=OneWay}"
                        LabelText="{Binding DisplayName}"
                        Mode="{x:Bind TitleIconMode, Mode=OneWay}" />
                    <TextBlock
                        x:Name="TitleText"
                        FontSize="{Binding TitleTextSize}"
                        Text="{Binding DisplayName}"
                        TextTrimming="CharacterEllipsis"
                        VerticalAlignment="Center" />
                    <ContentPresenter
                        x:Name="TitleEditorPresenter"
                        Content="{x:Bind TitleEditorContent, Mode=OneWay}"
                        Visibility="Collapsed" />
                </StackPanel>

                <StackPanel
                    x:Name="RightActionButtons"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="4"
                    Opacity="0"
                    VerticalAlignment="Center">
                    <StackPanel
                        x:Name="HoverActionButtons"
                        Orientation="Horizontal"
                        Spacing="4">
                        <Button
                            x:Name="PositionLockButton"
                            Click="PositionLockButton_Click"
                            Style="{StaticResource WidgetTitleActionButtonStyle}">
                            <Grid>
                                <Path x:Name="PositionLockButtonIcon" Data="M10.12 3.14a2 2 0 0 1 3.2-.52l4.06 4.05a2 2 0 0 1-.52 3.2l-3.46 1.74a1.5 1.5 0 0 0-.72.78L11.25 16a1 1 0 0 1-1.64.33L7 13.7 3.7 17H3v-.7L6.3 13l-2.62-2.61a1 1 0 0 1 .34-1.64L7.6 7.32c.34-.14.62-.4.78-.72l1.73-3.46Zm2.5.18a1 1 0 0 0-1.6.26L9.29 7.04a2.5 2.5 0 0 1-1.31 1.2L4.39 9.69l5.93 5.93 1.43-3.59a2.5 2.5 0 0 1 1.2-1.3l3.46-1.74a1 1 0 0 0 .26-1.6l-4.05-4.06Z" Fill="{Binding Foreground, ElementName=PositionLockButton}" Stretch="Uniform" />
                                <Path x:Name="PositionLockButtonFilledIcon" Visibility="Collapsed" Data="M13.33 2.62a2 2 0 0 0-3.2.52L8.38 6.6a1.5 1.5 0 0 1-.78.72L4 8.75a1 1 0 0 0-.33 1.64l2.61 2.6L3 16.3v.7h.7L7 13.72l2.61 2.6a1 1 0 0 0 1.64-.33l1.43-3.59c.14-.34.4-.62.72-.78l3.46-1.73a2 2 0 0 0 .52-3.2l-4.05-4.06Z" Fill="{Binding Foreground, ElementName=PositionLockButton}" Stretch="Uniform" />
                            </Grid>
                        </Button>
                        <Button
                            x:Name="SizeLockButton"
                            Click="SizeLockButton_Click"
                            Style="{StaticResource WidgetTitleActionButtonStyle}">
                            <Grid>
                                <Path x:Name="SizeLockButtonIcon" Data="M10 1a4 4 0 0 1 4 4v2.05a2.5 2.5 0 0 1 2 2.45v6a2.5 2.5 0 0 1-2.5 2.5h-7A2.5 2.5 0 0 1 4 15.5v-6c0-1.2.86-2.22 2-2.45V5a4 4 0 0 1 4-4ZM6.5 8C5.67 8 5 8.67 5 9.5v6c0 .83.67 1.5 1.5 1.5h7c.83 0 1.5-.67 1.5-1.5v-6c0-.83-.67-1.5-1.5-1.5h-7Zm3.5 3.5a1 1 0 1 1 0 2 1 1 0 0 1 0-2ZM10 2a3 3 0 0 0-3 3v2h6V5a3 3 0 0 0-3-3Z" Fill="{Binding Foreground, ElementName=SizeLockButton}" Stretch="Uniform" />
                                <Path x:Name="SizeLockButtonFilledIcon" Visibility="Collapsed" Data="M10 1a4 4 0 0 1 4 4v2.05a2.5 2.5 0 0 1 2 2.45v6a2.5 2.5 0 0 1-2.5 2.5h-7A2.5 2.5 0 0 1 4 15.5v-6c0-1.2.86-2.22 2-2.45V5a4 4 0 0 1 4-4Zm0 10.5a1 1 0 1 0 0 2 1 1 0 0 0 0-2ZM10 2a3 3 0 0 0-3 3v2h6V5a3 3 0 0 0-3-3Z" Fill="{Binding Foreground, ElementName=SizeLockButton}" Stretch="Uniform" />
                            </Grid>
                        </Button>
                        <Button
                            x:Name="AddButton"
                            Click="AddButton_Click"
                            Style="{StaticResource WidgetTitleActionButtonStyle}"
                            Visibility="{x:Bind AddButtonVisibility, Mode=OneWay}">
                            <Path x:Name="AddButtonIcon" Data="M6 10c0-.28.22-.5.5-.5h3v-3a.5.5 0 0 1 1 0v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3A.5.5 0 0 1 6 10Zm4 8a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm0-1a7 7 0 1 1 0-14 7 7 0 0 1 0 14Z" Fill="{Binding Foreground, ElementName=AddButton}" Stretch="Uniform" />
                        </Button>
                        <Button
                            x:Name="MoreButton"
                            Click="MoreButton_Click"
                            Style="{StaticResource WidgetTitleActionButtonStyle}">
                            <Path x:Name="MoreButtonIcon" Data="M7 10a1 1 0 1 1-2 0 1 1 0 0 1 2 0Zm4 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0Zm4 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0Zm-5-8a8 8 0 1 0 0 16 8 8 0 0 0 0-16Zm-7 8a7 7 0 1 1 14 0 7 7 0 0 1-14 0Z" Fill="{Binding Foreground, ElementName=MoreButton}" Stretch="Uniform" />
                        </Button>
                        <Button
                            x:Name="CloseButton"
                            Click="CloseButton_Click"
                            Style="{StaticResource WidgetTitleActionButtonStyle}">
                            <Path x:Name="CloseButtonIcon" Data="M8.5 4h3a1.5 1.5 0 0 0-3 0Zm-1 0a2.5 2.5 0 0 1 5 0h5a.5.5 0 0 1 0 1h-1.05l-1.2 10.34A3 3 0 0 1 12.27 18H7.73a3 3 0 0 1-2.98-2.66L3.55 5H2.5a.5.5 0 0 1 0-1h5ZM5.74 15.23A2 2 0 0 0 7.73 17h4.54a2 2 0 0 0 1.99-1.77L15.44 5H4.56l1.18 10.23ZM8.5 7.5c.28 0 .5.22.5.5v6a.5.5 0 0 1-1 0V8c0-.28.22-.5.5-.5ZM12 8a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V8Z" Fill="{Binding Foreground, ElementName=CloseButton}" Stretch="Uniform" />
                        </Button>
                    </StackPanel>
                    <Button
                        x:Name="CollapseButton"
                        Click="CollapseButton_Click"
                        Style="{StaticResource WidgetTitleActionButtonStyle}">
                        <FontIcon FontSize="12" Glyph="&#xE70E;" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <Border
            x:Name="HeaderDivider"
            Grid.Row="0"
            Height="1"
            Margin="12,0"
            VerticalAlignment="Bottom" />

        <ContentPresenter
            x:Name="ShellContentPresenter"
            Grid.Row="1"
            Content="{x:Bind ShellContent, Mode=OneWay}" />

        <Grid
            x:Name="CollapsedChromeLayer"
            Grid.RowSpan="2"
            Canvas.ZIndex="45"
            Padding="8,0,6,0"
            Background="Transparent"
            Visibility="Collapsed"
            GotFocus="CollapsedChromeLayer_GotFocus"
            LostFocus="CollapsedChromeLayer_LostFocus"
            PointerCaptureLost="OverlayDragHandle_PointerCaptureLost"
            PointerMoved="OverlayDragHandle_PointerMoved"
            PointerPressed="OverlayDragHandle_PointerPressed"
            PointerReleased="OverlayDragHandle_PointerReleased"
            SizeChanged="CollapsedChromeLayer_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid
                x:Name="CompactIdentityHost"
                Width="28"
                Height="28"
                VerticalAlignment="Center"
                Background="Transparent"
                PointerEntered="CompactIdentityHost_PointerEntered"
                PointerExited="CompactIdentityHost_PointerExited">
                <controls:WidgetTitleIcon
                    x:Name="CompactTitleIcon"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    AccentColor="{x:Bind TitleIconAccentColor, Mode=OneWay}"
                    Glyph="{x:Bind TitleGlyph, Mode=OneWay}"
                    IconSize="14"
                    IconKind="{x:Bind TitleIconKind, Mode=OneWay}"
                    LabelText="{x:Bind OverlayTitle, Mode=OneWay}"
                    Mode="{x:Bind TitleIconMode, Mode=OneWay}" />
                <Border
                    x:Name="CompactThumbnailHost"
                    Width="28"
                    Height="28"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="8"
                    Visibility="Collapsed">
                    <Image x:Name="CompactThumbnail" Stretch="UniformToFill" />
                </Border>
                <Border
                    x:Name="CompactIdentityRegionHighlight"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                    BorderThickness="1"
                    IsHitTestVisible="False"
                    Opacity="0" />
            </Grid>

            <Grid
                x:Name="CompactTextContainer"
                Grid.Column="1"
                MinWidth="0"
                Margin="6,0,7,0"
                VerticalAlignment="Stretch"
                Background="Transparent"
                PointerEntered="CompactTextContainer_PointerEntered"
                PointerExited="CompactTextContainer_PointerExited">
                <StackPanel
                    x:Name="CompactTextHost"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="6">
                    <StackPanel.RenderTransform>
                        <TranslateTransform x:Name="CompactTextTransform" />
                    </StackPanel.RenderTransform>
                    <Grid x:Name="CompactTitleViewport" Height="18">
                        <Canvas x:Name="CompactTitleMarqueeCanvas">
                            <TextBlock
                                x:Name="CompactTitleText"
                                VerticalAlignment="Center"
                                FontSize="12.5"
                                FontWeight="SemiBold"
                                MaxLines="1"
                                TextWrapping="NoWrap"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                x:Name="CompactTitleMarqueeClone"
                                VerticalAlignment="Center"
                                FontSize="12.5"
                                FontWeight="SemiBold"
                                MaxLines="1"
                                TextWrapping="NoWrap"
                                TextTrimming="Clip"
                                Visibility="Collapsed" />
                        </Canvas>
                    </Grid>
                    <Border
                        x:Name="CompactTextSeparator"
                        Width="3"
                        Height="3"
                        VerticalAlignment="Center"
                        Background="{ThemeResource TextFillColorTertiaryBrush}"
                        CornerRadius="2" />
                    <Grid x:Name="CompactSummaryViewport" Height="17">
                        <Canvas x:Name="CompactSummaryMarqueeCanvas">
                            <TextBlock
                                x:Name="CompactSummaryText"
                                MinWidth="0"
                                VerticalAlignment="Center"
                                FontSize="11.5"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                MaxLines="1"
                                TextWrapping="NoWrap"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                x:Name="CompactSummaryMarqueeClone"
                                MinWidth="0"
                                VerticalAlignment="Center"
                                FontSize="11.5"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                MaxLines="1"
                                TextWrapping="NoWrap"
                                TextTrimming="Clip"
                                Visibility="Collapsed" />
                        </Canvas>
                    </Grid>
                </StackPanel>
            </Grid>

            <Border
                x:Name="CompactActionRegionHighlight"
                Grid.Column="1"
                Grid.ColumnSpan="3"
                Width="24"
                Margin="0,1,0,1"
                HorizontalAlignment="Right"
                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                BorderThickness="1"
                Canvas.ZIndex="40"
                IsHitTestVisible="False"
                Opacity="0" />

            <Border
                x:Name="CompactActionRegionTrigger"
                Grid.Column="1"
                Grid.ColumnSpan="3"
                Width="24"
                HorizontalAlignment="Right"
                Background="#01000000"
                Canvas.ZIndex="41"
                PointerEntered="CompactActionRegionTrigger_PointerEntered"
                PointerExited="CompactActionRegionTrigger_PointerExited" />

            <Border
                x:Name="CompactReorderHandle"
                Grid.Column="3"
                Width="18"
                Height="28"
                Margin="0,0,2,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#01000000"
                Canvas.ZIndex="44"
                Opacity="0"
                PointerEntered="CompactReorderHandle_PointerEntered"
                PointerExited="CompactReorderHandle_PointerExited"
                Visibility="Collapsed">
                <Grid
                    x:Name="CompactReorderGlyph"
                    Width="7"
                    Height="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Opacity="0.58">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Ellipse Width="2" Height="2" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Ellipse Grid.Column="1" Width="2" Height="2" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Ellipse Grid.Row="1" Width="2" Height="2" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Ellipse Grid.Row="1" Grid.Column="1" Width="2" Height="2" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Ellipse Grid.Row="2" Width="2" Height="2" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Ellipse Grid.Row="2" Grid.Column="1" Width="2" Height="2" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>
            </Border>

            <StackPanel
                x:Name="CompactActionHost"
                Grid.Column="1"
                Grid.ColumnSpan="3"
                Margin="0,0,2,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Canvas.ZIndex="43"
                Opacity="0"
                PointerEntered="CompactActionHost_PointerEntered"
                PointerExited="CompactActionHost_PointerExited"
                Spacing="2"
                IsHitTestVisible="False">
                <Button
                    x:Name="CompactPrimaryActionButton"
                    Click="CompactPrimaryActionButton_Click"
                    Style="{StaticResource WidgetTitleActionButtonStyle}"
                    Visibility="Collapsed">
                    <FontIcon x:Name="CompactPrimaryActionIcon" FontSize="12" Glyph="&#xE73E;" />
                </Button>
                <Button
                    x:Name="CompactPreviousButton"
                    Click="CompactPreviousButton_Click"
                    Style="{StaticResource WidgetTitleActionButtonStyle}"
                    Visibility="Collapsed">
                    <FontIcon FontSize="12" Glyph="&#xE100;" />
                </Button>
                <Button
                    x:Name="CompactPlayPauseButton"
                    Click="CompactPlayPauseButton_Click"
                    Style="{StaticResource WidgetTitleActionButtonStyle}"
                    Visibility="Collapsed">
                    <FontIcon x:Name="CompactPlayPauseIcon" FontSize="12" Glyph="&#xE102;" />
                </Button>
                <Button
                    x:Name="CompactNextButton"
                    Click="CompactNextButton_Click"
                    Style="{StaticResource WidgetTitleActionButtonStyle}"
                    Visibility="Collapsed">
                    <FontIcon FontSize="12" Glyph="&#xE101;" />
                </Button>
                <Button
                    x:Name="CompactExpandButton"
                    Click="CompactExpandButton_Click"
                    Style="{StaticResource WidgetTitleActionButtonStyle}">
                    <FontIcon FontSize="12" Glyph="&#xE70D;" />
                </Button>
            </StackPanel>

            <Grid
                x:Name="CompactLiveIndicatorHost"
                Grid.ColumnSpan="4"
                Height="2"
                Margin="8,0,8,2"
                VerticalAlignment="Bottom"
                IsHitTestVisible="False">
                <Border
                    x:Name="CompactLiveTrack"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="1"
                    Opacity="0"
                    Visibility="Collapsed" />
                <Border
                    x:Name="CompactLiveProgress"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="1"
                    Opacity="0"
                    RenderTransformOrigin="0,0.5"
                    Visibility="Collapsed">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="CompactLiveProgressTransform" ScaleX="0" />
                    </Border.RenderTransform>
                </Border>
                <Border
                    x:Name="CompactLiveEventIndicator"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="1"
                    Opacity="0" />
            </Grid>
        </Grid>

        <Grid
            x:Name="OverlayChromeLayer"
            Grid.RowSpan="2"
            Canvas.ZIndex="30"
            Visibility="Collapsed">
            <Border
                x:Name="OverlayIdentityHost"
                MinHeight="28"
                MaxWidth="210"
                Margin="8,8,0,0"
                Padding="9,5,10,5"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0.8"
                CornerRadius="8"
                IsHitTestVisible="False"
                Opacity="0">
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="6">
                    <controls:WidgetTitleIcon
                        x:Name="OverlayTitleIcon"
                        AccentColor="{x:Bind TitleIconAccentColor, Mode=OneWay}"
                        Glyph="{x:Bind TitleGlyph, Mode=OneWay}"
                        IconSize="12"
                        IconKind="{x:Bind TitleIconKind, Mode=OneWay}"
                        LabelText="{x:Bind OverlayTitle, Mode=OneWay}"
                        Mode="{x:Bind TitleIconMode, Mode=OneWay}"
                        VerticalAlignment="Center" />
                    <TextBlock
                        x:Name="OverlayTitleText"
                        MaxWidth="170"
                        FontSize="12"
                        Text="{x:Bind OverlayTitle, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <Border
                x:Name="OverlayDragHandle"
                Width="72"
                Height="24"
                Margin="0"
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Background="#01000000"
                BorderThickness="0"
                Opacity="0"
                PointerCaptureLost="OverlayDragHandle_PointerCaptureLost"
                PointerEntered="OverlayDragHandle_PointerEntered"
                PointerExited="OverlayDragHandle_PointerExited"
                PointerMoved="OverlayDragHandle_PointerMoved"
                PointerPressed="OverlayDragHandle_PointerPressed"
                PointerReleased="OverlayDragHandle_PointerReleased">
                <Grid
                    Width="32"
                    Height="12"
                    Margin="0,2,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top">
                    <Border
                        x:Name="OverlayDragGrip"
                        Width="28"
                        Height="4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Background="{ThemeResource TextFillColorSecondaryBrush}"
                        CornerRadius="2"
                        Opacity="0.76" />
                    <Path
                        x:Name="OverlayCollapseChevron"
                        Width="26"
                        Height="11"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Data="M2,8 L13,3 L24,8"
                        Opacity="0"
                        Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                        StrokeEndLineCap="Round"
                        StrokeLineJoin="Round"
                        StrokeStartLineCap="Round"
                        StrokeThickness="4" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
